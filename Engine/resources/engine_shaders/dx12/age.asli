template <typename t, typename t_sample>
float4
sample(texture_2d<t> tex, t_sample s, float2 location)
{
	return tex.Sample(s, location);
}

template <typename t>
float
sample_cmp(texture_2d<t> tex, sampler_cmp_state s, float2 location, float compare_value)
{
	return tex.SampleCmp(s, location, compare_value);
}

template <typename t>
float
sample_cmp_level_zero(texture_2d<t> tex, sampler_cmp_state s, float2 location, float compare_value)
{
	return tex.SampleCmpLevelZero(s, location, compare_value);
}

template <typename t>
t
load(texture_2d<t> tex, int32 x, int32 y, uint32 mip = 0)
{
	return tex.Load(int32_3(x, y, mip));
}

template <typename t>
t
load(texture_2d<t> tex, float x, float y, uint32 mip = 0)
{
	return tex.Load(int32_3(x, y, mip));
}

// rt
// ── lifecycle ──

template <uint32 rt_flags>
void
rt_trace_ray_inline(
	ray_query<rt_flags>		  q,
	rt_acceleration_structure accel,
	uint32					  ray_flags,
	uint32					  instance_mask,
	ray_desc				  ray)
{ q.TraceRayInline(accel, ray_flags, instance_mask, ray); }

template <uint32 rt_flags>
bool
rt_proceed(ray_query<rt_flags> q)
{ return q.Proceed(); }

template <uint32 rt_flags>
void
rt_abort(ray_query<rt_flags> q)
{ q.Abort(); }

// ── candidate judgment ──

template <uint32 rt_flags>
uint32
rt_candidate_type(ray_query<rt_flags> q)
{ return q.CandidateType(); }

template <uint32 rt_flags>
void
rt_commit_non_opaque_triangle_hit(ray_query<rt_flags> q)
{ q.CommitNonOpaqueTriangleHit(); }

template <uint32 rt_flags>
void
rt_commit_procedural_primitive_hit(ray_query<rt_flags> q, float t_hit)
{ q.CommitProceduralPrimitiveHit(t_hit); }

