static const uint32 CANDIDATE_NON_OPAQUE_TRIANGLE  = 0;
static const uint32 CANDIDATE_PROCEDURAL_PRIMITIVE = 1;

static const uint32 COMMITTED_NOTHING				   = 0;
static const uint32 COMMITTED_TRIANGLE_HIT			   = 1;
static const uint32 COMMITTED_PROCEDURAL_PRIMITIVE_HIT = 2;

static const uint32 RAY_FLAG_NONE							 = 0x00;
static const uint32 RAY_FLAG_FORCE_OPAQUE					 = 0x01;
static const uint32 RAY_FLAG_FORCE_NON_OPAQUE				 = 0x02;
static const uint32 RAY_FLAG_ACCEPT_FIRST_HIT_AND_END_SEARCH = 0x04;
static const uint32 RAY_FLAG_SKIP_CLOSEST_HIT_SHADER		 = 0x08;
static const uint32 RAY_FLAG_CULL_BACK_FACING_TRIANGLES		 = 0x10;
static const uint32 RAY_FLAG_CULL_FRONT_FACING_TRIANGLES	 = 0x20;
