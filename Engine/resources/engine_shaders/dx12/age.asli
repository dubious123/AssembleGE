static const uint32 RAY_FLAG_SKIP_PROCEDURAL_PRIMITIVES		 = 0x200;

// ── types ──

struct rt_acceleration_structure
{ };

struct ray_desc
{
	float3 Origin;
	float  TMin;
	float3 Direction;
	float  TMax;
};

// ── ray_query ──

template <uint32 rt_flags>
struct ray_query
{
	// lifecycle
	void
	TraceRayInline(
		rt_acceleration_structure accel,
		uint32					  ray_flags,
		uint32					  instance_mask,
		ray_desc				  ray)
	{ return; }

	bool
	Proceed()
	{ return false; }

	void
	Abort()
	{ return; }

	// ── candidate (valid inside Proceed loop) ──

	uint32
	CandidateType()
	{ return 0; }

	void
	CommitNonOpaqueTriangleHit()
	{ return; }

	void
	CommitProceduralPrimitiveHit(float t_hit)
	{ return; }

	float2
	CandidateTriangleBarycentrics()
	{ return (float2)0; }

	bool
	CandidateTriangleFrontFace()
	{ return false; }

	float
	CandidateTriangleRayT()
	{ return 0.0; }

	uint32
	CandidateInstanceID()
	{ return 0; }

	uint32
	CandidateInstanceIndex()
	{ return 0; }

	uint32
	CandidateGeometryIndex()
	{ return 0; }

	uint32
	CandidatePrimitiveIndex()
	{ return 0; }

	uint32
	CandidateInstanceContributionToHitGroupIndex()
	{ return 0; }

	float3
	CandidateObjectRayOrigin()
	{ return (float3)0; }

	float3
	CandidateObjectRayDirection()
	{ return (float3)0; }

	float3x4
	CandidateObjectToWorld3x4()
	{ return (float3x4)0; }

	float3x4
	CandidateWorldToObject3x4()
	{ return (float3x4)0; }

	// ── committed (valid after Proceed returns false) ──

	uint32
	CommittedStatus()
	{ return 0; }

	float2
	CommittedTriangleBarycentrics()
	{ return (float2)0; }

	bool
	CommittedTriangleFrontFace()
	{ return false; }

	float
	CommittedRayT()
	{ return 0.0; }

	uint32
	CommittedInstanceID()
	{ return 0; }

	uint32
	CommittedInstanceIndex()
	{ return 0; }

	uint32
	CommittedGeometryIndex()
	{ return 0; }

	uint32
	CommittedPrimitiveIndex()
	{ return 0; }

	uint32
	CommittedInstanceContributionToHitGroupIndex()
	{ return 0; }

	float3
	CommittedObjectRayOrigin()
	{ return (float3)0; }

	float3
	CommittedObjectRayDirection()
	{ return (float3)0; }

	float3x4
	CommittedObjectToWorld3x4()
	{ return (float3x4)0; }

	float3x4
	CommittedWorldToObject3x4()
	{ return (float3x4)0; }

	// ── common ray intrinsics ──

	uint32
	RayFlags()
	{ return 0; }

	float3
	WorldRayOrigin()
	{ return (float3)0; }

	float3
	WorldRayDirection()
	{ return (float3)0; }

	float
	RayTMin()
	{ return 0.0; }
};

