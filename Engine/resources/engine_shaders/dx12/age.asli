template <typename t>
t
load(byte_address_buffer buffer, uint32 offset)
{
	return buffer.Load<t>(offset);
}

template <typename t>
t
load(rw_byte_address_buffer buffer, uint32 offset)
{
	return buffer.Load<t>(offset);
}

template <typename t>
void
store(rw_byte_address_buffer buffer, uint32 offset, t value)
{
	return buffer.Store<t>(offset, value);
}

