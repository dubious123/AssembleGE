// light buffer
byte_address_buffer	   light_cull_stage_buffer_srv reg(t0, space1);
rw_byte_address_buffer light_cull_stage_buffer_uav reg(u0, space1);

structured_buffer<unified_light>	sorted_light_buffer_srv reg(t1, space1);
rw_structured_buffer<unified_light> sorted_light_buffer_uav reg(u1, space1);

void
store_sorted_light(uint32 idx, unified_light data)
{
	sorted_light_buffer_uav[idx] = data;
}

unified_light
load_sorted_light(uint32 idx)
{
	return sorted_light_buffer_srv[idx];
}

void
store_zbin_entry(uint32 idx, zbin_entry data)
{
	store<zbin_entry>(light_cull_stage_buffer_uav, LIGHT_CULL_ZBIN_OFFSET + idx * sizeof(zbin_entry), data);
}

void
store_zbin_entry_interlocked_min(uint32 idx, uint32 min_idx)
{
	buf_interlocked_min(light_cull_stage_buffer_uav, LIGHT_CULL_ZBIN_OFFSET + idx * sizeof(zbin_entry) + sizeof(uint32) * 0, min_idx);
}

void
store_zbin_entry_interlocked_max(uint32 idx, uint32 max_idx)
{
	buf_interlocked_max(light_cull_stage_buffer_uav, LIGHT_CULL_ZBIN_OFFSET + idx * sizeof(zbin_entry) + sizeof(uint32) * 1, max_idx);
}

zbin_entry
load_zbin_entry(uint32 idx)
{
	return load<zbin_entry>(light_cull_stage_buffer_srv, LIGHT_CULL_ZBIN_OFFSET + idx * sizeof(zbin_entry));
}

void
store_tile_mask(uint32 tile_idx, uint32 word_idx, uint32 mask)
{
	store<uint32>(light_cull_stage_buffer_uav, LIGHT_CULL_TILE_MASK_OFFSET + (tile_idx * LIGHT_BITMASK_UINT32_COUNT + word_idx) * sizeof(uint32), mask);
}

void
store_tile_mask_flat(uint32 idx, uint32 mask)
{
	store<uint32>(light_cull_stage_buffer_uav, LIGHT_CULL_TILE_MASK_OFFSET + idx * sizeof(uint32), mask);
}

uint32
load_tile_mask(uint32 tile_idx, uint32 word_idx)
{
	return load<uint32>(light_cull_stage_buffer_srv, LIGHT_CULL_TILE_MASK_OFFSET + (tile_idx * LIGHT_BITMASK_UINT32_COUNT + word_idx) * sizeof(uint32));
}

// material
structured_buffer<material> material_buffer reg(t0, space2);

material
load_material(uint32 idx)
{
	if (idx == invalid_id_uint32)
	{
		material m;
		m.base_color_factor	   = float4(1.0, 1.0, 1.0, 1.0);
		m.metallic_factor	   = 0.0;
		m.roughness_factor	   = 0.5;
		m.emissive_factor	   = float3(0.0, 0.0, 0.0);
		m.normal_scale		   = 1.0;
		m.occlusion_strength   = 1.0;
		m.alpha_cutoff		   = 0.5;
		m.alpha_mode_and_extra = 0;	   // alpha_mode = opaque(0), extra = 0
		m._					   = uint2(0, 0);

		m.base_color_texture_id			= invalid_id_uint32;
		m.metallic_roughness_texture_id = invalid_id_uint32;
		m.normal_texture_id				= invalid_id_uint32;
		m.occlusion_texture_id			= invalid_id_uint32;
		m.emissive_texture_id			= invalid_id_uint32;

		return m;
	}
	else
	{
		return material_buffer[idx];
	}
}

// env_light
structured_buffer<env_light> env_light_buffer reg(t1, space2);

env_light
load_env_light(uint32 idx)
{
	return env_light_buffer[idx];
}

// rt
structured_buffer<rt_instance_render_data> rt_instance_render_data_buffer_srv reg(t0, space3);
structured_buffer<uint32>				   rt_index_buffer_srv reg(t1, space3);
structured_buffer<raycast_request>		   rt_raycast_request_buffer_srv reg(t2, space3);
rw_structured_buffer<raycast_result>	   rt_raycast_result_buffer_uav reg(u3, space3);

rt_instance_render_data
load_rt_instance_render_data(uint32 instance_id)
{
	return rt_instance_render_data_buffer_srv[instance_id];
}

uint32_3
load_rt_triangle_index(rt_instance_render_data data, uint32 triangle_idx)
{
	return uint32_3(
		rt_index_buffer_srv[data.rt_index_buffer_offset + triangle_idx * 3 + 0],
		rt_index_buffer_srv[data.rt_index_buffer_offset + triangle_idx * 3 + 1],
		rt_index_buffer_srv[data.rt_index_buffer_offset + triangle_idx * 3 + 2]);
}

raycast_request
load_rt_raycast_request(uint32 raycast_id)
{
	return rt_raycast_request_buffer_srv[raycast_id];
}

void
store_rt_raycast_result(uint32 raycast_id, raycast_result res)
{
	rt_raycast_result_buffer_uav[raycast_id] = res;
}

