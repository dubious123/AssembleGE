byte_address_buffer static_buffer reg(t0, space0);

opaque_meshlet_render_data
load_opaque_meshlet_render_data(uint32 idx)
{
	return load<opaque_meshlet_render_data>(static_buffer, OPAQUE_MSHLT_OBJECT_DATA_OFFSET + idx * sizeof(opaque_meshlet_render_data));
}

object_data
load_object_data(uint32 idx)
{
	return load<object_data>(static_buffer, OBJECT_DATA_OFFSET + idx * sizeof(object_data));
}

directional_light
load_directional_light(uint32 idx)
{
	return load<directional_light>(static_buffer, DIRECTIONAL_LIGHT_OFFSET + idx * sizeof(directional_light));
}

unified_light
load_unified_light(uint32 idx)
{
	return load<unified_light>(static_buffer, UNIFIED_LIGHT_OFFSET + idx * sizeof(unified_light));
}

byte_address_buffer mesh_data_buffer reg(t1, space0);

// uav only
rw_byte_address_buffer scratch_buffer reg(u0, space0);

// alt is uniform — compiler folds to branchless select or eliminates dead path
uint32
sort_key_offset(bool alt)
{
	return alt ? SORT_KEYS_ALT_OFFSET : SORT_KEYS_OFFSET;
}

uint32
sort_value_offset(bool alt)
{
	return alt ? SORT_VALUES_ALT_OFFSET : SORT_VALUES_OFFSET;
}

void
store_sort_key(uint32 idx, uint32 key, uint32 base_offset)
{
	store<uint32>(scratch_buffer, base_offset + idx * sizeof(uint32), key);
}

uint32
load_sort_key(uint32 idx, uint32 base_offset)
{
	return load<uint32>(scratch_buffer, base_offset + idx * sizeof(uint32));
}

void
store_sort_value(uint32 idx, uint32 value, uint32 base_offset)
{
	store<uint32>(scratch_buffer, base_offset + idx * sizeof(uint32), value);
}

uint32
load_sort_value(uint32 idx, uint32 base_offset)
{
	return load<uint32>(scratch_buffer, base_offset + idx * sizeof(uint32));
}

void
store_sort_histogram(uint32 idx, uint32 value)
{
	store<uint32>(scratch_buffer, SORT_HISTOGRAM_OFFSET + idx * sizeof(uint32), value);
}

uint32
load_sort_histogram(uint32 idx)
{
	return load<uint32>(scratch_buffer, SORT_HISTOGRAM_OFFSET + idx * sizeof(uint32));
}

void
store_sort_histogram_interlocked_add(uint32 idx, uint32 value)
{
	buf_interlocked_add(scratch_buffer, SORT_HISTOGRAM_OFFSET + idx * sizeof(uint32), value);
}

void
store_sort_bin_count(uint32 idx, uint32 value)
{
	store<uint32>(scratch_buffer, SORT_BIN_COUNT_OFFSET + idx * sizeof(uint32), value);
}

uint32
load_sort_bin_count(uint32 idx)
{
	return load<uint32>(scratch_buffer, SORT_BIN_COUNT_OFFSET + idx * sizeof(uint32));
}

void
store_packed_aabb(uint32 idx, uint32 packed)
{
	store<uint32>(scratch_buffer, LIGHT_CULL_PACKED_AABB_OFFSET + idx * sizeof(uint32), packed);
}

uint32
load_packed_aabb(uint32 idx)
{
	return load<uint32>(scratch_buffer, LIGHT_CULL_PACKED_AABB_OFFSET + idx * sizeof(uint32));
}

void
store_visible_light_count(uint32 count)
{
	store<uint32>(scratch_buffer, VISIBLE_LIGHT_COUNT_OFFSET, count);
}

void
store_visible_light_count_interlocked_add(uint32 value)
{
	buf_interlocked_add(scratch_buffer, VISIBLE_LIGHT_COUNT_OFFSET, value);
}

uint32
load_visible_light_count()
