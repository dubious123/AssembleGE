// opaque
struct opaque_as_to_ms
{
	uint32 meshlet_32_group_idx;
	uint32 meshlet_alive_mask;
};

struct opaque_ms_to_ps
{
	vertex_fat					  v;
	nointerpolation uint32 mat_id semantics(material);
};

struct debug_ms_to_ps
{
	vertex_fat							v;
	nointerpolation uint32 debug_obj_id semantics(debug_obj_id);
};

struct selection_outline_ms_to_ps
{
	float4 position										  sv_position;
	nointerpolation uint32 selection_outline_id_and_extra semantics(id_and_extra);
};

// light culling tile mask
struct tile_mask_ms_to_ps
{
	float4 pos						 sv_position;
	nointerpolation uint32 sorted_id semantics(sorted_id);
};

// presentation

struct presentation_ps_out
{
	float4 color semantics(color);
};
