static const float pi				= 3.1415926535897932384626433832795f;
static const float pi_2				= 6.283185307179586476925286766559f;
static const float pi_inv			= 0.31830988618379067153776752674503f;
static const float pi_2_inv			= 0.15915494309189533576888376337251f;
static const float pi_div_2			= 1.5707963267948966192313216916398f;
static const float pi_half			= pi_div_2;
static const float pi_div_4			= 0.78539816339744830961566084581988f;
