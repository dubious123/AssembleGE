uint32
bit_width(uint32 u)
{
	return u == 0 ? 0 : (first_bit_high(u) + 1);
}

float
length_sq(float2 v)
{
	return dot(v, v);
}

float
length_sq(float3 v)
{
	return dot(v, v);
}

float
length_sq(float4 v)
{
	return dot(v, v);
}

float3
reject(float3 a, float3 b)
{
	return a - (dot(a, b) / length_sq(b)) * b;
}

float3
reject_norm(float3 a, float3 b_norm)
{
	return normalize(a - dot(b_norm, a) * b_norm);
}

bool
is_nan(float v)
{
	return isnan(v);
}

bool
is_nan(float2 v)
{
	return isnan(v.x) || isnan(v.y);
}

bool
is_nan(float3 v)
{
	return isnan(v.x) || isnan(v.y) || isnan(v.z);
}

bool
is_nan(float4 v)
{
	return isnan(v.x) || isnan(v.y) || isnan(v.z) || isnan(v.w);
}

float
pow_5(float x)
{
	return x * x * x * x * x;
}

float3
to_float3(float x)
{
	return float3(x, x, x);
}

bool
get_bit(uint32 value, uint32 bit_idx)
{
	return (value >> bit_idx) & 1u;
}

uint32
get_bits(uint32 value, uint32 bit_idx, uint32 bit_count)
{
	return (value >> bit_idx) & ((1u << bit_count) - 1u);
}

float
int8_to_float(uint32 raw)
{
	return float(int((raw & 0xffu) << 24) >> 24);
}

float
snorm8_to_float(int32 raw)
{
	return ((raw << 24) >> 24) / 127.f;
}

float
unorm8_to_float(uint32 raw)
{
	return (raw & 0xffu) / 255.f;
}

float
snorm16_to_float(int32 raw)
{
	return ((raw << 16) >> 16) / 32767.f;
}

// float
// snorm16_to_float(int32 raw)
//{
//	return max(((raw << 16) >> 16) / 32767.f, -1.f);
// }

float
unorm16_to_float(uint32 raw)
{
	return (raw & 0xffffu) / 65535.f;
}

uint16
float_to_snorm8(float f)
{
	int32 v = int32(clamp(f, -1.f, 1.f) * 127.f + (f >= 0.f ? 0.5f : -0.5f));
	return uint16(v) & 0xff;
}

uint16
float_to_snorm16(float f)
{
	int32 v = int32(clamp(f, -1.f, 1.f) * 32767.f + (f >= 0.f ? 0.5f : -0.5f));
	return uint16(v) & 0xffff;
}

uint16
float_to_unorm8(float f)
{
	uint32 v = uint32(saturate(f) * 255.f + 0.5f);
	return uint16(v) & 0xff;
}

uint16
float_to_unorm16(float f)
{
	uint32 v = uint32(saturate(f) * 65535.f + 0.5f);
	return uint16(v) & 0xffff;
}

template <typename t_ret = int32>
t_ret
uint32_x_to_int8(uint32 u)
{
	return cast<t_ret>(int32(u << 24) >> 24);
}

template <typename t_ret = int32>
t_ret
uint32_y_to_int8(uint32 u)
{
	return cast<t_ret>(int32(u << 16) >> 24);
}

template <typename t_ret = int32>
t_ret
uint32_z_to_int8(uint32 u)
{
	return cast<t_ret>(int32(u << 8) >> 24);
}

template <typename t_ret = int32>
t_ret
uint32_w_to_int8(uint32 u)
{
	return cast<t_ret>(int32(u) >> 24);
}

template <typename t_ret = uint32>
t_ret
uint32_x_to_uint8(uint32 u)
{
	return cast<t_ret>((u >> 0) & 0xff);
}

template <typename t_ret = uint32>
t_ret
uint32_y_to_uint8(uint32 u)
{
	return cast<t_ret>((u >> 8) & 0xff);
}

template <typename t_ret = uint32>
t_ret
uint32_z_to_uint8(uint32 u)
{
	return cast<t_ret>((u >> 16) & 0xff);
}

template <typename t_ret = uint32>
t_ret
uint32_w_to_uint8(uint32 u)
{
	return cast<t_ret>((u >> 24) & 0xff);
}

int16
uint32_upper_to_int16(uint32 u)
{
	return int16(u >> 16);
}

int16
uint32_lower_to_int16(uint32 u)
{
	return int16(u & 0xffff);
}

uint16
uint32_upper_to_uint16(uint32 u)
{
	return uint16(u >> 16);
}

uint16
uint32_lower_to_uint16(uint32 u)
{
	return uint16(u & 0xffff);
}

half
uint32_lower_to_half(uint32 u)
{
	return as_float16(uint32_lower_to_uint16(u));
}

half
uint32_upper_to_half(uint32 u)
{
	return as_float16(uint32_upper_to_uint16(u));
}

half2
uint32_to_half2(uint32 u)
{
	return half2(uint32_lower_to_half(u), uint32_upper_to_half(u));
}

