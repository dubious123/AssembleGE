// Sebastien Lagarde 2014
// Inverse Trigonometric functions GPU optimization for AMD GCN architecture
// https://seblagarde.wordpress.com/2014/12/01/inverse-trigonometric-functions-gpu-optimization-for-amd-gcn-architecture/

// max absolute error 9.0x10^-3
// Eberly's polynomial degree 1 - respect bounds
// 4 VGPR, 12 FR (8 FR, 1 QR), 1 scalar
// input [-1, 1] and output [0, PI]
float
fast_acos(float inX)
{
	float x	   = abs(inX);
	float res  = -0.156583f * x + pi_half;
	res		  *= sqrt(1.0f - x);
	return (inX >= 0) ? res : pi - res;
}

// Same cost as Acos + 1 FR
// Same error
// input [-1, 1] and output [-PI/2, PI/2]
float
fast_asin(float x)
{
	return pi_half - fast_acos(x);
}

// max absolute error 1.3x10^-3
// Eberly's odd polynomial degree 5 - respect bounds
// 4 VGPR, 14 FR (10 FR, 1 QR), 2 scalar
// input [0, infinity] and output [0, PI/2]
float
fast_atan_pos(float x)
{
	float t0   = (x < 1.0f) ? x : 1.0f / x;
	float t1   = t0 * t0;
	float poly = 0.0872929f;
	poly	   = -0.301895f + poly * t1;
	poly	   = 1.0f + poly * t1;
	poly	   = poly * t0;
	return (x < 1.0f) ? poly : pi_half - poly;
}

// 4 VGPR, 16 FR (12 FR, 1 QR), 2 scalar
// input [-infinity, infinity] and output [-PI/2, PI/2]
float
fast_atan(float x)
{
	float t0 = fast_atan_pos(abs(x));
	return (x < 0.0f) ? -t0 : t0;
}

template <typename t>
t
zero()
{
	return (t)0;
}

uint32
ceil(uint32 x, uint32 y)
{
	return (x + y - 1) / y;
}

template <template <typename, int32> class vec, int32 n, typename t_l, typename t_r>
vec<t_l, n>
ceil(vec<t_l, n> x, t_r y)
{
	return (x + y - 1) / y;
}

// assume align is power of 2
uint32
align_up(uint32 offset, uint32 align)
{
	// (offset + align - 1) / align * align
	return (offset + align - 1) & ~(align - 1);
}

template <typename t>
t
max(t x, t y, t z)
{
	return max(max(x, y), z);
}

template <typename t>
t
max(t x, t y, t z, t w)
{
	return max(max(x, y), max(z, w));
}

template <typename t>
t
min(t x, t y, t z)
{
	return min(min(x, y), z);
}

template <typename t>
t
min(t x, t y, t z, t w)
{
	return min(min(x, y), min(z, w));
}

template <typename t>
t
max(const in vector<t, 2> v)
{
	return max(v.x, v.y);
}

template <typename t>
t
max(const in vector<t, 3> v)
{
	return max(max(v.x, v.y), v.z);
}

template <typename t>
t
max(const in vector<t, 4> v)
{
	return max(max(v.x, v.y), max(v.z, v.w));
}

template <typename t>
t
min(const in vector<t, 2> v)
{
	return min(v.x, v.y);
}

template <typename t>
t
min(const in vector<t, 3> v)
{
	return min(min(v.x, v.y), v.z);
}

template <typename t>
t
min(const in vector<t, 4> v)
{
	return min(min(v.x, v.y), min(v.z, v.w));
}

