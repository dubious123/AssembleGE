		load_ray_entry(const gibs_data data, uint32 id)
		{
			byte_address_buffer buf = global_resource_buffer[data.h_ray_entry_buffer_srv_id];

			return load<gibs_ray_entry>(buf, data.ray_entry_buffer_offset() + sizeof(gibs_ray_entry) * id);
		}
