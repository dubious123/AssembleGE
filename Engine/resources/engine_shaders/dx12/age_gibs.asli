namespace gibs
{
	rw_byte_array<half>
	load_lum_rw_arr(const gibs_data data, uint32 surfel_id, bool is_tile)
	{
		const uint32 uav_id = is_tile ? data.h_tile_surfel_luminance_buffer_uav_id
									  : data.h_cell_surfel_luminance_buffer_uav_id;
		const uint32 offset = is_tile ? sizeof(half) * data.atlas_texel_count() * surfel_id
									  : sizeof(half) * data.atlas_texel_count() * surfel_id;

		return rw_byte_array<half>::init(global_resource_buffer[non_uniform_resource_idx(uav_id)], offset, data.atlas_texel_count());
	}

	rw_byte_array<half>
	load_lum_cdf_rw_arr(const gibs_data data, uint32 surfel_id, bool is_tile)
	{
		const uint32 uav_id = is_tile ? data.h_tile_surfel_luminance_buffer_uav_id
									  : data.h_cell_surfel_luminance_buffer_uav_id;
		const uint32 offset = is_tile ? sizeof(half) * data.atlas_texel_count() * (data.max_tile_surfel_count + surfel_id)
									  : sizeof(half) * data.atlas_texel_count() * (data.max_cell_surfel_count + surfel_id);


		return rw_byte_array<half>::init(global_resource_buffer[non_uniform_resource_idx(uav_id)], offset, data.atlas_texel_count());
	}

	byte_array<half>
	load_lum_cdf_arr(const gibs_data data, uint32 surfel_id, bool is_tile)
	{
		const uint32 srv_id = is_tile ? data.h_tile_surfel_luminance_buffer_srv_id
									  : data.h_cell_surfel_luminance_buffer_srv_id;
		const uint32 offset = is_tile ? sizeof(half) * data.atlas_texel_count() * (data.max_tile_surfel_count + surfel_id)
									  : sizeof(half) * data.atlas_texel_count() * (data.max_cell_surfel_count + surfel_id);


		return byte_array<half>::init(global_resource_buffer[non_uniform_resource_idx(srv_id)], offset, data.atlas_texel_count());
	}

	rw_byte_array<uint16>
	load_vis_rw_arr(const gibs_data data, uint32 surfel_id, bool is_tile)
	{
		const uint32 uav_id = is_tile ? data.h_tile_surfel_visibility_buffer_uav_id
									  : data.h_cell_surfel_visibility_buffer_uav_id;
		const uint32 offset = is_tile ? sizeof(uint16) * data.atlas_texel_count() * surfel_id
									  : sizeof(uint16) * data.atlas_texel_count() * surfel_id;


		return rw_byte_array<uint16>::init(global_resource_buffer[non_uniform_resource_idx(uav_id)], offset, data.atlas_texel_count());
	}
