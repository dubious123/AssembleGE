gibs_alloc_ray(const gibs_data data, uint32 ray_count)
{
	atomic_counter counter = atomic_counter::init(global_resource_buffer[data.h_ray_buffer_uav_id], data.ray_count_total_offset());
	return counter.inc(ray_count);
}

