}

//---[ logics ]------------------------------------------------------------------------------------------------------
float3
gibs_calc_cell_origin(const gibs_lut_data lut_data)
{
	return round(gi_origin / lut_data.cell_size_arr[0]) * lut_data.cell_size_arr[0];
}

uint32
gibs_flatten_tile_idx(const gibs_data data, uint32_2 tile_idx)
{
	return tile_idx.y * data.tile_count_w + tile_idx.x;
}

half
gibs_calc_tile_surfel_radius(const gibs_data data, const gibs_lut_data lut_data, const surfel surfel)
{
	const float3 rel	   = surfel.position - camera_pos;
	const float	 distance  = length(rel);
	const float	 cos_theta = dot(rel / distance, camera_forward);

	const float radius = distance * lut_data.surfel_distance_to_tile_radius * cos_theta * cos_theta;

	return cast<half>(radius);
	// return min(radius, cell_size);
	// return clamp(radius, cell_size * 0.15f, cell_size);
	// return clamp(radius, cell_size * 0.15f, cell_size * 0.7);
}

template <typename t_func>
void
gibs_foreach_neighbor_tile(inout t_func fn, const gibs_data data, const uint32_2 screen_pos)
{
	const int32_2 tile_center_idx = screen_pos / GIBS_GI_RESOLVE_TILE_SIZE;
	int32		  x_min			  = tile_center_idx.x <= 0 ? 0 : -1;
	int32		  y_min			  = tile_center_idx.y <= 0 ? 0 : -1;
	int32		  x_max			  = tile_center_idx.x >= data.tile_count_w - 1 ? 0 : 1;
	int32		  y_max			  = tile_center_idx.y >= data.tile_count_h - 1 ? 0 : 1;

	for (int32 y = y_min; y <= y_max; ++y)
	{
		for (int32 x = x_min; x <= x_max; ++x)
		{
			const int32_2 tile_idx = tile_center_idx + int32_2(x, y);

			fn(data, tile_idx);
		}
	}
}

float3
gibs_calc_cube_min(const gibs_lut_data lut_data, uint32 layer)
{
	return gibs_calc_cell_origin(lut_data) - lut_data.layer_boundary_arr[layer];
}

uint32
gibs_calc_layer(const gibs_data data, const gibs_lut_data lut_data, const float3 world_pos)
{
	const float3 rel  = world_pos - gibs_calc_cell_origin(lut_data);
	const float	 axis = max(abs(rel));

	expand_all()

	for (uint32 i = 0; i < GIBS_MAX_OUTER_LAYER_COUNT; ++i)
	{
		if (axis <= lut_data.layer_boundary_arr[i])
		{
			return i;
		}
	}

	return data.outer_layer_count;
}

uint32
gibs_calc_layer(const gibs_data data, const gibs_lut_data lut_data, const surfel surfel)
{
	return gibs_calc_layer(data, lut_data, surfel.position);
}

float
gibs_calc_cell_size(const gibs_data data, const gibs_lut_data lut_data, const surfel surfel)
{
	return lut_data.cell_size_arr[gibs_calc_layer(data, lut_data, surfel)];
}

half
gibs_calc_cell_surfel_radius(const gibs_data data, const gibs_lut_data lut_data, const surfel surfel)
{
	const float distance = length(surfel.position - gibs_calc_cell_origin(lut_data));

	const float radius = distance * lut_data.surfel_distance_to_cell_radius;

	const float cell_size = gibs_calc_cell_size(data, lut_data, surfel);
	return cast<half>(cell_size);
	return cast<half>(radius);
	// return max(radius, cell_size * 0.15f);
	// return radius;
	// return cast<half>(min(radius, cell_size));
	// return clamp(radius, cell_size * 0.15f, cell_size);
	// return clamp(radius, cell_size * 0.15f, cell_size * 0.7);
}

uint32
gibs_flatten_cell_idx(const gibs_data data, int32_4 cell_idx)
{
	const int32 region = cell_idx.w;
	if (region == 0)
	{
		uint32_3 cell_idx_uint32 = cell_idx.xyz + (data.cell_count >> 1);

		return cell_idx_uint32.x
			 + cell_idx_uint32.y * data.cell_count
			 + cell_idx_uint32.z * data.cell_count * data.cell_count;
	}

	// layer >= 1
	const uint32 layer = cell_idx.z;

	const uint32 base_offset = data.cell_count * data.cell_count * data.cell_count
							 + 6 * data.cell_count * data.cell_count * (layer - 1)
							 + (region - 1) * data.cell_count * data.cell_count;

	const int32_2 cell_idx_xy = cell_idx.xy + int32(data.cell_count >> 1);
	assert(all(cell_idx_xy >= 0), g::fmt_gibs, line);


	const uint32 res = base_offset
					 + cell_idx_xy.x
					 + cell_idx_xy.y * data.cell_count;

	assert(res < data.cell_count_total, g::fmt_gibs, line);
	return res;
}

float3
gibs_calc_region(float3 xyz, out int32 region)
{
	const float3 xyz_abs = abs(xyz);
	float3		 xyz_res = (float3)0;

	if (xyz_abs.x >= xyz_abs.y and xyz_abs.x >= xyz_abs.z)
	{
		if (xyz.x > 0)
		{
			xyz_res.x = -xyz.z;
			xyz_res.y = xyz.y;
			xyz_res.z = xyz.x;
			region	  = 1;
		}
		else
		{
			xyz_res.x = xyz.z;
			xyz_res.y = xyz.y;
			xyz_res.z = -xyz.x;
			region	  = 2;
		}
	}
	else if (xyz_abs.y >= xyz_abs.x and xyz_abs.y >= xyz_abs.z)
	{
		if (xyz.y > 0)
		{
			xyz_res.x = xyz.x;
			xyz_res.y = -xyz.z;
			xyz_res.z = xyz.y;
			region	  = 3;
		}
		else
		{
			xyz_res.x = xyz.x;
			xyz_res.y = xyz.z;
			xyz_res.z = -xyz.y;
			region	  = 4;
		}
	}
	else
	{
		if (xyz.z > 0)
		{
			xyz_res.x = xyz.x;
			xyz_res.y = xyz.y;
			xyz_res.z = xyz.z;
			region	  = 5;
		}
		else
		{
			xyz_res.x = -xyz.x;
			xyz_res.y = xyz.y;
			xyz_res.z = -xyz.z;
			region	  = 6;
		}
	}

	return xyz_res;
}

int32_4
gibs_calc_cell_idx(const gibs_data data, const gibs_lut_data lut_data, const float3 world_pos)
{
	const uint32 layer = gibs_calc_layer(data, lut_data, world_pos);

	const float3 rel = world_pos - gibs_calc_cell_origin(lut_data);

	const int32 half = data.cell_count >> 1u;

	int32 region = 0;

	if (layer == 0)
	{
		const float3 cell_idx_float = floor(rel / lut_data.cell_size_arr[0]);

		return int32_4(clamp(int32_3(cell_idx_float), -half, half - 1), region);
	}

	const float3 region_xyz = gibs_calc_region(rel, region);

	const float	 cell_size_xy	   = region_xyz.z * 2.f / data.cell_count;
	const float2 cell_idx_float_xy = floor(region_xyz.xy / cell_size_xy);

	return int32_4(clamp(int32_2(cell_idx_float_xy), -half, half - 1), layer, region);
}

int32_4
gibs_calc_cell_idx(const gibs_data data, const gibs_lut_data lut_data, const surfel surfel)
{
	return gibs_calc_cell_idx(data, lut_data, surfel.position);
}

bool
gibs_surfel_cell_intersect(const gibs_data data, const gibs_lut_data lut_data, const surfel surfel, int32_4 cell_idx)
{
	const float3 rel	= surfel.position - gibs_calc_cell_origin(lut_data);
	const int32	 region = cell_idx.w;

	if (region == 0)
	{
		const float	 cell_size = lut_data.cell_size_arr[0];
		const float3 cell_min  = cell_idx.xyz * cell_size;
		const float3 cell_max  = cell_min + cell_size;

		return sphere_aabb_intersect(rel, surfel.radius, cell_min, cell_max);
	}
	else
	{
		const int32 layer = cell_idx.z;
		const float min_z = lut_data.layer_boundary_arr[layer - 1];
		const float max_z = lut_data.layer_boundary_arr[layer];

		int32_3 cell_idx_world = cell_idx.xyz;

		const float cell_size_near_uv = min_z * 2.f / data.cell_count;
		const float cell_size_far_uv  = max_z * 2.f / data.cell_count;

		float3 cell_near_low;
		float3 cell_near_high;
		float3 cell_far_low;
		float3 cell_far_high;

		// maybe there are better ways to do this, but i can't think of one
		if (region == 1)
		{
			cell_near_low.yz = float2(cell_idx.y, -cell_idx.x) * cell_size_near_uv;
			cell_near_low.x	 = min_z;
			cell_far_low.yz	 = float2(cell_idx.y, -cell_idx.x) * cell_size_far_uv;
			cell_far_low.x	 = max_z;

			cell_near_high.yz = float2(cell_idx.y + 1, -cell_idx.x - 1) * cell_size_near_uv;
			cell_near_high.x  = min_z;
			cell_far_high.yz  = float2(cell_idx.y + 1, -cell_idx.x - 1) * cell_size_far_uv;
			cell_far_high.x	  = max_z;
		}
		else if (region == 2)
		{
			cell_near_low.yz = float2(cell_idx.y, cell_idx.x) * cell_size_near_uv;
			cell_near_low.x	 = -min_z;
			cell_far_low.yz	 = float2(cell_idx.y, cell_idx.x) * cell_size_far_uv;
			cell_far_low.x	 = -max_z;

			cell_near_high.yz = float2(cell_idx.y + 1, cell_idx.x + 1) * cell_size_near_uv;
			cell_near_high.x  = -min_z;
			cell_far_high.yz  = float2(cell_idx.y + 1, cell_idx.x + 1) * cell_size_far_uv;
			cell_far_high.x	  = -max_z;
		}
		else if (region == 3)
		{
			cell_near_low.xz = float2(cell_idx.x, -cell_idx.y /*- 1*/) * cell_size_near_uv;
			cell_near_low.y	 = min_z;
			cell_far_low.xz	 = float2(cell_idx.x, -cell_idx.y /*- 1*/) * cell_size_far_uv;
			cell_far_low.y	 = max_z;

			cell_near_high.xz = float2(cell_idx.x + 1, -cell_idx.y - 1) * cell_size_near_uv;
			cell_near_high.y  = min_z;
			cell_far_high.xz  = float2(cell_idx.x + 1, -cell_idx.y - 1) * cell_size_far_uv;
			cell_far_high.y	  = max_z;
		}
		else if (region == 4)
		{
			cell_near_low.xz = float2(cell_idx.x, cell_idx.y) * cell_size_near_uv;
			cell_near_low.y	 = -min_z;
			cell_far_low.xz	 = float2(cell_idx.x, cell_idx.y) * cell_size_far_uv;
			cell_far_low.y	 = -max_z;

			cell_near_high.xz = float2(cell_idx.x + 1, cell_idx.y + 1) * cell_size_near_uv;
			cell_near_high.y  = -min_z;
			cell_far_high.xz  = float2(cell_idx.x + 1, cell_idx.y + 1) * cell_size_far_uv;
			cell_far_high.y	  = -max_z;
		}
		else if (region == 5)
		{
			cell_near_low.xy = float2(cell_idx.x, cell_idx.y) * cell_size_near_uv;
			cell_near_low.z	 = min_z;
			cell_far_low.xy	 = float2(cell_idx.x, cell_idx.y) * cell_size_far_uv;
			cell_far_low.z	 = max_z;

			cell_near_high.xy = float2(cell_idx.x + 1, cell_idx.y + 1) * cell_size_near_uv;
			cell_near_high.z  = min_z;
			cell_far_high.xy  = float2(cell_idx.x + 1, cell_idx.y + 1) * cell_size_far_uv;
			cell_far_high.z	  = max_z;
		}
		else
		{
			// region == 6
			cell_near_low.xy = float2(-cell_idx.x /* - 1*/, cell_idx.y) * cell_size_near_uv;
			cell_near_low.z	 = -min_z;
			cell_far_low.xy	 = float2(-cell_idx.x /* - 1*/, cell_idx.y) * cell_size_far_uv;
			cell_far_low.z	 = -max_z;

			cell_near_high.xy = float2(-cell_idx.x - 1, cell_idx.y + 1) * cell_size_near_uv;
			cell_near_high.z  = -min_z;
			cell_far_high.xy  = float2(-cell_idx.x - 1, cell_idx.y + 1) * cell_size_far_uv;
			cell_far_high.z	  = -max_z;
		}


		return sphere_aabb_intersect(rel, surfel.radius,
									 min(cell_near_low, cell_near_high, cell_far_low, cell_far_high),
									 max(cell_near_low, cell_near_high, cell_far_low, cell_far_high));
	}
}

template <typename t_func>
void
gibs_foreach_neighbor_cell(inout t_func fn, const gibs_data data, const gibs_lut_data lut_data, const float3 world_pos)
{
	const int32_4 center_cell_idx = gibs_calc_cell_idx(data, lut_data, world_pos);

	const int32 region = center_cell_idx.w;

	const int32 half = data.cell_count >> 1u;

	static const int32_3 offset_arr[26] = {
		int32_3(1, 1, 1),
		int32_3(1, 1, -1),
		int32_3(1, -1, 1),
		int32_3(1, -1, -1),
		int32_3(-1, 1, 1),
		int32_3(-1, 1, -1),
		int32_3(-1, -1, 1),
		int32_3(-1, -1, -1),

		int32_3(1, 1, 0),
		int32_3(1, -1, 0),
		int32_3(-1, 1, 0),
		int32_3(-1, -1, 0),

		int32_3(1, 0, 1),
		int32_3(1, 0, -1),
		int32_3(-1, 0, 1),
		int32_3(-1, 0, -1),

		int32_3(0, 1, 1),
		int32_3(0, 1, -1),
		int32_3(0, -1, 1),
		int32_3(0, -1, -1),


		int32_3(1, 0, 0),
		int32_3(-1, 0, 0),
		int32_3(0, 1, 0),
		int32_3(0, -1, 0),
		int32_3(0, 0, 1),
		int32_3(0, 0, -1),
	};

	fn(data, lut_data, center_cell_idx);
	if (region == 0)
	{
		expand_all()

		for (uint32 i = 0; i < 26; ++i)
		{
			const int32_3 offset = offset_arr[i];
			const int32_3 coord	 = center_cell_idx.xyz + offset;

			const bool x_warp_neg = coord.x < -half;
			const bool x_warp_pos = coord.x >= half;

			const bool y_warp_neg = coord.y < -half;
			const bool y_warp_pos = coord.y >= half;

			const bool z_warp_neg = coord.z < -half;
			const bool z_warp_pos = coord.z >= half;

			if ((x_warp_neg or x_warp_pos) + (y_warp_neg or y_warp_pos) + (z_warp_neg or z_warp_pos) > 1) { continue; }

			int32_4 res;
			if (x_warp_pos)
			{
				res.x = -coord.z - 1;
				res.y = coord.y;
				res.z = 1;
				res.w = 1;
			}
			else if (x_warp_neg)
			{
				res.x = coord.z;
				res.y = coord.y;
				res.z = 1;
				res.w = 2;
			}
			else if (y_warp_pos)
			{
				res.x = coord.x;
				res.y = -coord.z - 1;
				res.z = 1;
				res.w = 3;
			}
			else if (y_warp_neg)
			{
				res.x = coord.x;
				res.y = coord.z;
				res.z = 1;
				res.w = 4;
			}
			else if (z_warp_pos)
			{
				res.x = coord.x;
				res.y = coord.y;
				res.z = 1;
				res.w = 5;
			}
			else if (z_warp_neg)
			{
				res.x = -coord.x - 1;
				res.y = coord.y;
				res.z = 1;
				res.w = 6;
			}
			else
			{
				res.xyz = coord;
				res.w	= 0u;
			}

			fn(data, lut_data, res);
		}
	}
	else
	{
		expand_all()

		for (uint32 i = 0; i < 26; ++i)
		{
			const int32	  layer	 = center_cell_idx.z;
			const int32_3 offset = offset_arr[i];
			const int32_3 coord	 = center_cell_idx.xyz + offset;

			const bool x_warp_neg = coord.x < -half;
			const bool x_warp_pos = coord.x >= half;

			const bool y_warp_neg = coord.y < -half;
			const bool y_warp_pos = coord.y >= half;

			const bool z_warp_neg = offset.z == -1;
			const bool z_warp_pos = offset.z == 1;

			if ((x_warp_neg or x_warp_pos) + (y_warp_neg or y_warp_pos) + (layer == 1 and z_warp_neg) > 1) { continue; }
			if (layer == data.outer_layer_count and z_warp_pos) { continue; }

			int32_4 res;

			res.z = coord.z;
			res.w = center_cell_idx.w;	  // region

			// axis flip => -x-1
			// y = -half -> x = half - 1, y = half - 1 => x = - half
			// y = -x-1
			if (x_warp_pos)
			{
				if (region == 1)
				{
					// x_pos -> z_neg
					res.x = -half;
					res.y = coord.y;
					res.w = 6;
				}
				else if (region == 2)
				{
					// x_neg -> z_pos
					res.x = -half;
					res.y = coord.y;
					res.w = 5;
				}
				else if (region == 3)
				{
					// y_pos -> x_pos
					res.x = coord.y;
					res.y = half - 1;
					res.w = 1;
				}
				else if (region == 4)
				{
					// y_neg -> x_pos
					res.x = -coord.y - 1;
					res.y = -half;
					res.w = 1;
				}
				else if (region == 5)
				{
					// z_pos -> x_pos
					res.x = -half;
					res.y = coord.y;
					res.w = 1;
				}
				else
				{
					// region == 6
					// z_neg -> x_neg
					res.x = -half;
					res.y = coord.y;
					res.w = 2;
				}
			}
			else if (x_warp_neg)
			{
				if (region == 1)
				{
					// x_pos -> z_pos
					res.x = half - 1;
					res.y = coord.y;
					res.w = 5;
				}
				else if (region == 2)
				{
					// x_neg -> z_neg
					res.x = half - 1;
					res.y = coord.y;
					res.w = 6;
				}
				else if (region == 3)
				{
					// y_pos -> x_neg
					res.x = -coord.y - 1;
					res.y = half - 1;
					res.w = 2;
				}
				else if (region == 4)
				{
					// y_neg -> x_neg
					res.x = coord.y;
					res.y = -half;
					res.w = 2;
				}
				else if (region == 5)
				{
					// z_pos -> x_neg
					res.x = half - 1;
					res.y = coord.y;
					res.w = 2;
				}
				else
				{
					// region == 6
					// z_neg -> x_pos
					res.x = half - 1;
					res.y = coord.y;
					res.w = 1;
				}
			}
			else if (y_warp_pos)
			{
				if (region == 1)
				{
					// x_pos -> y_pos
					res.x = half - 1;
					res.y = coord.x;
					res.w = 3;
				}
				else if (region == 2)
				{
					// x_neg -> y_pos
					res.x = -half;
					res.y = -coord.x - 1;
					res.w = 3;
				}
				else if (region == 3)
				{
					// y_pos -> z_neg
					res.x = -coord.x - 1;
					res.y = half - 1;
					res.w = 6;
				}
				else if (region == 4)
				{
					// y_neg -> z_pos
					res.x = coord.x;
					res.y = -half;
					res.w = 5;
				}
				else if (region == 5)
				{
					// z_pos -> y_pos
					res.x = coord.x;
					res.y = -half;
					res.w = 3;
				}
				else
				{
					// region == 6
					// z_neg -> y_pos
					res.x = -coord.x - 1;
					res.y = half - 1;
					res.w = 3;
				}
			}
			else if (y_warp_neg)
			{
				if (region == 1)
				{
					// x_pos -> y_neg
					res.x = half - 1;
					res.y = -coord.x - 1;
					res.w = 4;
				}
				else if (region == 2)
				{
					// x_neg -> y_neg
					res.x = -half;
					res.y = coord.x;
					res.w = 4;
				}
				else if (region == 3)
				{
					// y_pos -> z_pos
					res.x = coord.x;
					res.y = half - 1;
					res.w = 5;
				}
				else if (region == 4)
				{
					// y_neg -> z_neg
					res.x = -coord.x - 1;
					res.y = -half;
					res.w = 6;
				}
				else if (region == 5)
				{
					// z_pos -> y_neg
					res.x = coord.x;
					res.y = half - 1;
					res.w = 4;
				}
				else
				{
					// region == 6
					// z_neg -> y_neg
					res.x = -coord.x - 1;
					res.y = -half;
					res.w = 4;
				}
			}
			else if (layer == 1 and z_warp_neg)
			{
				if (region == 1)
				{
					res.x = half - 1;
					res.y = coord.y;
					res.z = -coord.x - 1;
				}
				else if (region == 2)
				{
					res.x = -half;
					res.y = coord.y;
					res.z = coord.x;
				}
				else if (region == 3)
				{
					res.x = coord.x;
					res.y = half - 1;
					res.z = -coord.y - 1;
				}
				else if (region == 4)
				{
					res.x = coord.x;
					res.y = -half;
					res.z = coord.y;
				}
				else if (region == 5)
				{
					res.x = coord.x;
					res.y = coord.y;
					res.z = half - 1;
				}
				else
				{
					// region == 6
					res.x = -coord.x - 1;
					res.y = coord.y;
					res.z = -half;
				}

				res.w = 0;
			}
			else
			{
				res.xy = coord.xy;
			}

			fn(data, lut_data, res);
		}
	}
}

template <bool is_fallback = false>
float
gibs_calc_surfel_contribution(const gibs_data data, const surfel surfel, const float3 world_pos, const float3 normal)
{
	const float	 effective_radius = is_fallback ? surfel.radius * GIBS_SURFEL_OUTER_RADIUS_FACTOR : surfel.radius;
	const float3 rel			  = world_pos - surfel.position;
	const float	 dist_sq		  = dot(rel, rel);

	if (dist_sq > effective_radius * effective_radius) { return 0.f; }

	const float3 surfel_normal = decode_oct_snorm16(surfel.normal_oct_snorm16);

	const float cos_theta = dot(normal, surfel_normal);

	// const float cos_weight = cos_theta > 0.f ? 1.f : 1 + cos_theta;
	// return cos_weight * (1.f - sqrt(dist_sq) / effective_radius);
	if (cos_theta < 0.5f) { return 0.f; }

	// return abs(cos_theta) * (1.f - sqrt(dist_sq) / effective_radius);
	const float distance = sqrt(dist_sq);

	// return 1.f - smoothstep(0.25f * effective_radius, effective_radius, sqrt(dist_sq));
	// return (1.f - sqrt(dist_sq) / effective_radius);
	return smoothstep(0, 1, (1.f - sqrt(dist_sq) / effective_radius));
}

// based on ray-tracing-gems ch25
// https://github.com/Apress/ray-tracing-gems/blob/master/Ch_25_Hybrid_Rendering_for_Real-Time_Ray_Tracing/MultiscaleMeanEstimator.hlsl
// returns blend factor (catch_up_blend)
float3
gibs_update_msme(float3 y, inout surfel_msme msme, float blend_factor = GIBS_MSME_SHORT_WINDOW_BLEND)
{
	float3 mean_long	 = msme.mean_long;
	float3 mean_short	 = msme.mean_short;
	float3 variance		 = msme.variance;
	float  inconsistency = msme.inconsistency;
	float  vbbr			 = msme.vbbr;

	// Suppress fireflies.
	{
		const float3 dev			 = sqrt(max(1e-5f, variance));
		const float3 high_threshold	 = 0.1f + mean_short + dev * 8.f;
		const float3 overflow		 = max(0.f, y - high_threshold);
		y							-= overflow;
	}

	const float3 delta	= y - mean_short;
	mean_short			= lerp(mean_short, y, blend_factor);
	const float3 delta2 = y - mean_short;

	// This should be a longer window than shortWindowBlend to avoid bias
	// from the variance getting smaller when the short-term mean does.
	const float variance_blend = blend_factor * 0.5f;
	variance				   = lerp(variance, delta * delta2, variance_blend);
	variance				   = max(1e-3, variance);
	const float3 dev		   = sqrt(max(1e-5f, variance));

	const float3 short_diff	   = mean_long - mean_short;
	const float	 relative_diff = dot(float3(0.299f, 0.587f, 0.114f), abs(short_diff) / max(1e-5f, dev));
	inconsistency			   = lerp(inconsistency, relative_diff, 0.08f);

	const float vbbr_target = clamp(dot(float3(0.299f, 0.587f, 0.114f), 0.5f * mean_short / max(1e-5f, dev)), 1.f / 32.f, 1.f);

	float catch_up_blend  = clamp(smoothstep(0.f, 1.f, relative_diff * max(0.02f, inconsistency - 0.2f)), 1.f / 256.f, 1.f);
	catch_up_blend		 *= vbbr;

	vbbr	  = lerp(vbbr, vbbr_target, 0.1f);
	mean_long = lerp(mean_long, y, saturate(catch_up_blend));

	{
		const float incon_a	   = GIBS_MSME_INCON_BLEND;	   // tune
		float		incon_mean = msme.incon_mean;
		float		incon_var  = msme.incon_var;
		const float incon_d	   = inconsistency - incon_mean;
		incon_mean			   = lerp(incon_mean, inconsistency, incon_a);
		const float incon_d2   = inconsistency - incon_mean;
		incon_var			   = lerp(incon_var, incon_d * incon_d2, incon_a);
		msme.incon_mean		   = incon_mean;
		msme.incon_var		   = incon_var;
	}

	// output
	msme.mean_long	   = mean_long;
	msme.mean_short	   = mean_short;
	msme.vbbr		   = vbbr;
	msme.variance	   = variance;
	msme.inconsistency = inconsistency;

	return mean_long;
}

uint32
gibs_calc_tile_idx(const float3 local_dir)
{
	assert(local_dir.y >= 0.f, g::fmt_gibs, line);

	const float2 oct_uv = encode_world_hemi_octahedral(local_dir);							// [-1, 1]
	int32_2		 idx	= int32_2(floor((oct_uv * 0.5f + 0.5f) * GIBS_ATLAS_TILE_SIZE));	// [0, 6)
	idx					= min(idx, GIBS_ATLAS_TILE_SIZE - 1);

	return idx.y * GIBS_ATLAS_TILE_SIZE + idx.x;
}

float
gibs_calc_visibility(const gibs_data data, uint32 surfel_id, const surfel surfel, float3 world_pos)
{
	const float3 rel		   = world_pos - surfel.position;
	const float3 surfel_normal = decode_oct_snorm16(surfel.normal_oct_snorm16);
	const float3 rel_local	   = mul(rel, gen_world_normal_transform(surfel_normal));	 // mul (rel, inv(gen_world_normal_transform_t) )

	float3 dir_local = normalize(rel_local);

	// if (dir_local.y < -0.2f) { return 0.f; }
	if (all(world_pos == surfel.position)) { return 1.f; }

	dir_local.y = max(dir_local.y, epsilon_1e4);
	dir_local	= normalize(dir_local);

	assert(dir_local.y >= 0.f, g::fmt_gibs, line);

	const uint32 idx = gibs_calc_tile_idx(dir_local);

	const uint16 chebyshev_packed = gibs_load_surfel_visibility_arr(data, surfel_id)[idx];
	const float2 chebyshev		  = float2(unorm8_to_float(uint32_x_to_uint8(chebyshev_packed)), unorm8_to_float(uint32_y_to_uint8(chebyshev_packed)));

	const float dist_norm = saturate(length(rel) / (surfel.radius /* * GIBS_SURFEL_OUTER_RADIUS_FACTOR*/));
	const float mean	  = chebyshev.x;
	const float sq_mean	  = chebyshev.y;

	const float variance = abs(sq_mean - mean * mean);

	if (dist_norm <= mean) { return 1.f; }

	const float k	= dist_norm - mean;
	const float vis = variance / (variance + k * k);	// p(d >= mean + k) <= σ^2 / (σ^2 + k^2)
	return pow_5(vis);
}

float
calc_bilateral_weight(float center_z_lin, float3 center_normal, float target_z_lin, float3 target_normal, float2 ratio = float2(1.f, 1.f))
{
	const float depth_diff = abs(center_z_lin - target_z_lin) / max(center_z_lin, epsilon_1e4);
	const float w_depth	   = exp(-depth_diff * 100);
	const float w_normal   = pow(max(0.f, dot(center_normal, target_normal)), 8);

	return w_depth * w_normal * ratio.x * ratio.y;
}

float3
gibs_sample_screen_irradiance(float2 px, uint32 object_id, float3 world_pos, float3 normal)
{
	const gibs_data				data				  = gibs_load_gibs_data();
	byte_array<gibs_tile_entry> tile_entry_arr		  = gibs_load_tile_entry_arr(data);
	byte_array<uint32>			tile_to_surfel_id_arr = gibs_load_tile_to_surfel_id_arr(data);
	byte_array<surfel>			surfel_arr			  = gibs_load_surfel_arr(data);

	const uint32		  tile_id	 = gibs_flatten_tile_idx(data, uint32_2(px / GIBS_GI_RESOLVE_TILE_SIZE));
	const gibs_tile_entry tile_entry = tile_entry_arr[tile_id];

	float  max_contribution			  = 0.f;
	uint32 max_contribution_surfel_id = invalid_id_uint32;
	float4 radiance_shared			  = (float4)0;

	for (uint32 i = 0; i < min(512, tile_entry.surfel_count()); ++i)
	{
		const uint32 surfel_id = tile_to_surfel_id_arr[tile_entry.offset + i];
		const surfel surfel	   = surfel_arr[surfel_id];

		assert(surfel.surfel_seen(), g::fmt_gibs_gi_resolve, line);

		const float contribution = gibs_calc_surfel_contribution<false>(data, surfel, world_pos, normal);

		const float3 surfel_radiance = decode_r11g11b10(surfel.radiance_r11g11b10);

		assert(is_nan(surfel_radiance) is_false, g::fmt_gibs_gi_resolve, line);

		// assert(gibs_load_alive_surfel_id_stack_curr(data)[surfel.alive_idx] == surfel_id, g::fmt_gibs_gi_resolve, line);

		const float fallback_contribution = gibs_calc_surfel_contribution<true>(data, surfel, world_pos, normal);

		if (surfel.radius < epsilon_1e4 or contribution == 0.f) { continue; }

		// coverage += contribution;

		radiance_shared += float4(surfel_radiance, 1.f)
						 * fallback_contribution
						 * smoothstep(0.f, float(GIBS_RADIANCE_CACHE_DELAY), float(surfel.frame_since_born()))
						 * gibs_calc_visibility(data, surfel_id, surfel, world_pos);

		if (contribution > 0.f and max_contribution < contribution)
		{
			max_contribution		   = contribution;
			max_contribution_surfel_id = surfel_id;
		}
	}

	if (radiance_shared.w > 0.f)
	{
		radiance_shared.xyz /= radiance_shared.w;
		return radiance_shared.xyz;
	}
	else
	{
		texture_2d<float3> gi_resolve_buffer = global_resource_buffer[data.h_gi_resolve_curr_buffer_srv_id];

		// const float3 col_res = sample_level(gi_resolve_buffer, get_linear_clamp_sampler(), (float2(px) + 0.5f) * inv_backbuffer_size, 0);
		const float3 col_res = gi_resolve_buffer[px];

		attr_branch()

		if (((data.debug_flags & GIBS_DEBUG_FLAGS_FREEZE_SPAWN) == 0) and object_id != invalid_id_uint32)
		{
			const object_data obj = load_object_data(object_id);

			gibs_set_tile_surfel_spawn(data,
									   tile_id,
									   object_id,
									   rotate_inv(obj.quaternion, world_pos - obj.pos) / obj.scale,
									   encode_oct_snorm16(normalize(rotate_inv(obj.quaternion, normal) * obj.scale)),
									   encode_r11g11b10(col_res));
		}
		return col_res;
	}
}

float3
gibs_sample_irradiance(bool enable_spawn_kill, uint32 object_id, float3 world_pos, float3 normal)
{
	const gibs_data		data	 = gibs_load_gibs_data();
	const gibs_lut_data lut_data = gibs_load_gibs_lut_data();


	const float4   clip_pos		= mul(view_proj, float4(world_pos, 1.f));
	const float3   ndc			= clip_pos.xyz / clip_pos.w;
	const float2   screen_pos_f = ndc_xy_to_screen(ndc.xy, backbuffer_size);
	const uint32_2 screen_pos	= uint32_2(screen_pos_f);
	const bool	   in_screen	= clip_pos.w > 0.f
						   and all(ndc.xy >= -1.f)
						   and all(ndc.xy <= 1.f)
						   and ndc.z >= 0.f
						   and ndc.z <= 1.f;

	if (in_screen)
	{
		texture_2d<uint32_2> gbuffer		   = global_resource_buffer[opaque_gbuffer_srv_id];
		texture_2d<float>	 depth_buffer	   = global_resource_buffer[opaque_depth_buffer_srv_id];
		texture_2d<float3>	 gi_resolve_buffer = global_resource_buffer[data.h_gi_resolve_curr_buffer_srv_id];
		const float			 z_depth		   = load(depth_buffer, screen_pos);
		const float3		 px_normal		   = decode_oct_snorm16(gbuffer[screen_pos].y);

		const bool surfel_seen = z_depth != 0.f
							 and ndc.z >= (z_depth - epsilon_1e4)	 // z_depth + 0.5f - surfel - z_depth - 0.f(far)
							 and dot(px_normal, normal) > 0.9f;


		if (surfel_seen)
		{
			return gi_resolve_buffer[screen_pos];
		}

		// if (surfel_seen)
		//{
		//	const int32_2 extent = int32_2(backbuffer_size.x, backbuffer_size.y);

		//	const float2  base_f = screen_pos_f - 0.5f;
		//	const int32_2 px_00	 = clamp(int32_2(floor(base_f)), zero<int32_2>(), extent - 1);
		//	const int32_2 px_01	 = clamp(px_00 + int32_2(1, 0), zero<int32_2>(), extent - 1);
		//	const int32_2 px_10	 = clamp(px_00 + int32_2(0, 1), zero<int32_2>(), extent - 1);
		//	const int32_2 px_11	 = clamp(px_00 + int32_2(1, 1), zero<int32_2>(), extent - 1);

		//	const float2 f		  = frac(base_f);
		//	const float2 ratio_00 = float2(1.f - f.x, 1.f - f.y);
		//	const float2 ratio_01 = float2(f.x, 1.f - f.y);
		//	const float2 ratio_10 = float2(1.f - f.x, f.y);
		//	const float2 ratio_11 = float2(f.x, f.y);

		//	const float center_z_lin = calc_linear_z_reversed(cam_near_z, cam_far_z, ndc.z);

		//	const float z_lin_00 = calc_linear_z_reversed(cam_near_z, cam_far_z, depth_buffer[px_00]);
		//	const float z_lin_01 = calc_linear_z_reversed(cam_near_z, cam_far_z, depth_buffer[px_01]);
		//	const float z_lin_10 = calc_linear_z_reversed(cam_near_z, cam_far_z, depth_buffer[px_10]);
		//	const float z_lin_11 = calc_linear_z_reversed(cam_near_z, cam_far_z, depth_buffer[px_11]);

		//	const float3 normal_00 = decode_oct_snorm16(gbuffer[px_00].y);
		//	const float3 normal_01 = decode_oct_snorm16(gbuffer[px_01].y);
		//	const float3 normal_10 = decode_oct_snorm16(gbuffer[px_10].y);
		//	const float3 normal_11 = decode_oct_snorm16(gbuffer[px_11].y);

		//	float4 res	= zero<float4>();
		//	res		   += float4(gi_resolve_buffer[px_00], 1.f) * calc_bilateral_weight(center_z_lin, normal, z_lin_00, normal_00, ratio_00);
		//	res		   += float4(gi_resolve_buffer[px_01], 1.f) * calc_bilateral_weight(center_z_lin, normal, z_lin_01, normal_01, ratio_01);
		//	res		   += float4(gi_resolve_buffer[px_10], 1.f) * calc_bilateral_weight(center_z_lin, normal, z_lin_10, normal_10, ratio_10);
		//	res		   += float4(gi_resolve_buffer[px_11], 1.f) * calc_bilateral_weight(center_z_lin, normal, z_lin_11, normal_11, ratio_11);

		//	if (res.w > epsilon_1e4)
		//	{
		//		return res.xyz / res.w;
		//	}

		//	return gi_resolve_buffer[screen_pos];
		//}
	}

	world_pos += normal * 0.05f;

	const int32_4 cell_idx = gibs_calc_cell_idx(data, lut_data, world_pos);

	const uint32		  cell_idx_flat			= gibs_flatten_cell_idx(data, cell_idx);
	const gibs_cell_entry entry					= gibs_load_cell_entry_arr(data)[cell_idx_flat];
	byte_array<surfel>	  surfel_arr			= gibs_load_surfel_arr(data);
	byte_array<uint32>	  cell_to_surfel_id_arr = gibs_load_cell_to_surfel_id_arr(data);

	float4 irradiance_sum = (float4)0;	  // w = weight_sum

	uint32 max_contribution_surfel_id = invalid_id_uint32;
	float  max_contribution			  = 0.f;

	float contribution_sum = 0.f;
	for (uint32 i = 0; i < /*entry.surfel_count()*/ min(128, entry.surfel_count()); ++i)
	{
		const uint32 surfel_id	  = cell_to_surfel_id_arr[entry.offset + i];
		surfel		 surfel		  = surfel_arr[surfel_id];
		const float	 contribution = gibs_calc_surfel_contribution<false>(data, surfel, world_pos, normal);

		assert(surfel.surfel_seen() is_false, g::fmt_gibs, line);

		if (surfel.radius < epsilon_1e4 or contribution == 0.f) { continue; }

		contribution_sum += contribution;

		if (max_contribution < contribution)
		{
			max_contribution		   = contribution;
			max_contribution_surfel_id = surfel_id;
		}

		gibs_set_cell_surfel_ref(data, entry.offset + i);

		const float visibility = gibs_calc_visibility(data, surfel_id, surfel, world_pos);

		if (visibility < 1.f) { continue; }

		irradiance_sum += float4(decode_r11g11b10(surfel.radiance_r11g11b10), 1.f)
						* contribution
						* smoothstep(0.f, float(GIBS_RADIANCE_CACHE_DELAY), float(surfel.frame_since_born()))
						* gibs_calc_visibility(data, surfel_id, surfel, world_pos);
	}

	// add cell surfel gather pass
	attr_branch()

	if (enable_spawn_kill and ((data.debug_flags & GIBS_DEBUG_FLAGS_FREEZE_SPAWN) == 0))
	{
		if (contribution_sum < GIBS_SPAWN_COVERAGE)
		{
			assert(object_id != invalid_id_uint32, g::fmt_gibs, line);
			const object_data obj = load_object_data(object_id);

			gibs_set_cell_surfel_spawn(data,
									   cell_idx_flat,
									   object_id,
									   rotate_inv(obj.quaternion, world_pos - obj.pos) / obj.scale,
									   encode_oct_snorm16(normalize(rotate_inv(obj.quaternion, normal) * obj.scale)),
									   encode_r11g11b10(irradiance_sum.w == 0 ? float3(0, 0, 0) : irradiance_sum.xyz / irradiance_sum.w));
		}
		else if (contribution_sum > GIBS_KILL_COVERAGE or entry.surfel_count() > 128)
		{
			assert(max_contribution_surfel_id != invalid_id_uint32, g::fmt_gibs, line);
			gibs_set_cell_surfel_kill(data, cell_idx_flat, max_contribution_surfel_id);
		}
	}

	if (irradiance_sum.w > GIBS_SPAWN_COVERAGE * 0.5f)
	{
		return irradiance_sum.xyz / irradiance_sum.w;
	}
	// todo fallback

	// return color_red.xyz;
	return float3(0, 0, 0);
}

float4
gibs_gather_neighbor_gi(texture_2d<float3> irr_src, texture_2d<uint32_2> geo_src, int32_2 center, float center_z_lin, float3 center_n, int32_2 extent)
{
	float4 res = zero<float4>();

	const int32_2 r = int32_2(1, 1);

	for (int32 dy = -r.y; dy <= r.y; ++dy)
	{
		for (int32 dx = -r.x; dx <= r.x; ++dx)
		{
			const int32_2  tap			 = clamp(center + int32_2(dx, dy), zero<int32_2>(), extent - 1);
			const uint32_2 geo_tap		 = geo_src[tap];
			const float3   px_normal_tap = decode_oct_snorm16(geo_tap.x);
			const float	   px_depth_tap	 = as_float(geo_tap.y);

			if (geo_tap.y == 0) { continue; }

			const float px_z_lin_tap = calc_linear_z_reversed(cam_near_z, cam_far_z, px_depth_tap);

			const float w = calc_bilateral_weight(center_z_lin, center_n, px_z_lin_tap, px_normal_tap, float2(1.f, 1.f));

			res += float4(irr_src[tap], 1.f) * w;
		}
	}

	return res;
}