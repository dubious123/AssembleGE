#pragma once
#include "age.asli"

//---[ gibs data ]------------------------------------------------------------------------------------------------------
gibs_data
gibs_load_gibs_data()
{
	return load<gibs_data>(static_buffer, GIBS_DATA_OFFSET);
}

gibs_lut_data
gibs_load_gibs_lut_data()
{
	return load<gibs_lut_data>(static_buffer, GIBS_LUT_DATA_OFFSET);
}

bool
gibs_enabled()
{
	return ddgi_enabled_and_extra & 2;
}

//---[ gibs counter ]------------------------------------------------------------------------------------------------------
uint32
gibs_alloc_cell_surfel_offset(const gibs_data data, uint32 surfel_count)
{
	atomic_counter counter = atomic_counter::init(global_resource_buffer[data.h_scratch_buffer_uav_id], sizeof(uint32) * (3u + data.max_surfel_count * 3));
	return counter.inc(surfel_count);
}

void
gibs_atomic_add_ray_count_ideal(const gibs_data data, uint32 ray_count)
{
	atomic_counter counter = atomic_counter::init(global_resource_buffer[data.h_scratch_buffer_uav_id], sizeof(uint32) * (4u + data.max_surfel_count * 3));
	counter.inc(ray_count);
}

uint32
gibs_get_ray_count_ideal_total(const gibs_data data)
{
	rw_byte_address_buffer buf = global_resource_buffer[data.h_scratch_buffer_uav_id];
	return load<uint32>(buf, sizeof(uint32) * (4u + data.max_surfel_count * 3));
}

uint32
gibs_alloc_ray(const gibs_data data, uint32 ray_count)
{
	atomic_counter counter = atomic_counter::init(global_resource_buffer[data.h_scratch_buffer_uav_id], sizeof(uint32) * (5u + data.max_surfel_count * 3));
	return counter.inc(ray_count);
}

uint32
gibs_get_ray_count_total(const gibs_data data)
{
	atomic_counter counter = atomic_counter::init(global_resource_buffer[data.h_scratch_buffer_uav_id], sizeof(uint32) * (5u + data.max_surfel_count * 3));
	return counter.value();
}

void
gibs_reset_counter(const gibs_data data)
{
	atomic_counter::init(global_resource_buffer[data.h_scratch_buffer_uav_id], sizeof(uint32) * (3u + data.max_surfel_count * 3)).set(0);
	atomic_counter::init(global_resource_buffer[data.h_scratch_buffer_uav_id], sizeof(uint32) * (4u + data.max_surfel_count * 3)).set(0);
	atomic_counter::init(global_resource_buffer[data.h_scratch_buffer_uav_id], sizeof(uint32) * (5u + data.max_surfel_count * 3)).set(0);
}

