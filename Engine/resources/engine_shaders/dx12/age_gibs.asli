//---[ tile spawn kill ]---
void
gibs_set_tile_surfel_spawn(const gibs_data data, uint32 tile_sample_id, uint32 object_id, float3 local_pos, uint32 local_normal_oct_snorm16, uint32 radiance_packed)
{
	rw_byte_address_buffer buf = global_resource_buffer[data.h_tile_spawn_kill_buffer_uav_id];

	const uint32 offset = data.tile_spawn_kill_data_offset(tile_sample_id);

	uint32 original;
	buf_interlocked_compare_exchange(buf, offset, invalid_id_uint32, object_id, original);

	if (original == invalid_id_uint32)
	{
		store<float3>(buf, offset + sizeof(object_id), local_pos);
		store<uint32>(buf, offset + sizeof(object_id) + sizeof(local_pos), local_normal_oct_snorm16);
		store<uint32>(buf, offset + sizeof(object_id) + sizeof(local_pos) + sizeof(local_normal_oct_snorm16), radiance_packed);
	}
}

void
gibs_set_tile_surfel_kill(const gibs_data data, uint32 tile_sample_id, uint32 surfel_id)
{
	rw_byte_address_buffer buf = global_resource_buffer[data.h_tile_spawn_kill_buffer_uav_id];

	const uint32 offset = data.tile_spawn_kill_data_offset(tile_sample_id) + sizeof(uint32) + sizeof(float3) + sizeof(uint32) + sizeof(uint32);

	uint32 original;
	buf_interlocked_compare_exchange(buf, offset, invalid_id_uint32, surfel_id, original);
}

