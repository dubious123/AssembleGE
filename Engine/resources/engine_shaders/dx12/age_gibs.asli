//---[ ray count reduce ]------------------------------------------------------------------------------------------------------
uint32
gibs_get_ray_count_ideal_total(const gibs_data data)
{
	rw_byte_address_buffer buf = global_resource_buffer[data.h_scratch_buffer_uav_id];
	return load<uint32>(buf, data.ray_count_ideal_total_offset());
}

void
gibs_atomic_add_ray_count_ideal(const gibs_data data, uint32 ray_count)
{
	atomic_counter counter = atomic_counter::init(global_resource_buffer[data.h_scratch_buffer_uav_id], data.ray_count_ideal_total_offset());
	counter.inc(ray_count);
}

