//---[ logics ]------------------------------------------------------------------------------------------------------

namespace gibs
{
	template <typename t_geo, typename t_surfel>
	void
	update_world_space_surfel(const in t_geo geo, inout t_surfel surfel)
	{
		const object_data		 obj		 = load_object_data(geo.object_id);
		const object_render_data render_data = load_object_render_data(geo.object_id);
		const material			 mat		 = load_material(render_data.material_id);
		const mesh_header		 msh_header	 = read_mesh_header<object_render_data>(render_data);

		const uint32_3 primitive_idx = load_rt_triangle_index(render_data.rt_index_buffer_offset, geo.primitive_id);
		const float2   barycentrics	 = float2(unorm16_to_float(geo.barycentric_unorm16 & 0xffff), unorm16_to_float((geo.barycentric_unorm16 >> 16u) & 0xffff));
		const float3   bary_weights	 = float3(1.f - barycentrics.x - barycentrics.y, barycentrics.x, barycentrics.y);

		const vertex_fat v0 = decode_vertex(msh_header, primitive_idx.x);
		const vertex_fat v1 = decode_vertex(msh_header, primitive_idx.y);
		const vertex_fat v2 = decode_vertex(msh_header, primitive_idx.z);

		const vertex_fat v = transform_vertex_to_world(interpolate_vertex_fat(v0, v1, v2, bary_weights), obj);

		const pbr_surface_data surface_data = calc_pbr_surface(-v.normal, mat, v);

		const float3 local_face_normal = normalize(cross(v1.pos.xyz - v0.pos.xyz, v2.pos.xyz - v0.pos.xyz));
		const float3 world_face_normal = normalize(rotate(local_face_normal / cast<float3>(obj.scale), decode_quaternion(obj.quaternion)));

		surfel.normal_oct_snorm16 = encode_oct_snorm16(world_face_normal);
		surfel.position			  = surface_offset(v.world_pos, v.normal);
		surfel.radiance_r11g11b10 = encode_r11g11b10(calc_di<false>(surface_data, world_face_normal) + calc_gi(surface_data, decode_r11g11b10(surfel.irradiance_r11g11b10)));
	}

}	 // namespace gibs

namespace gibs
{
	template <typename t_func>
	void
	foreach_neighbor_cell(inout t_func fn, const gibs_data data, const gibs_lut_data lut_data, const float3 world_pos)
	{
		const int32_4 center_cell_idx = cell::calc_idx(data, lut_data, world_pos);

		const int32 region = center_cell_idx.w;

		const int32 half = data.cell_count >> 1u;

		static const int32_3 offset_arr[26] = {
			int32_3(1, 1, 1),
			int32_3(1, 1, -1),
			int32_3(1, -1, 1),
			int32_3(1, -1, -1),
			int32_3(-1, 1, 1),
			int32_3(-1, 1, -1),
			int32_3(-1, -1, 1),
			int32_3(-1, -1, -1),

			int32_3(1, 1, 0),
			int32_3(1, -1, 0),
			int32_3(-1, 1, 0),
			int32_3(-1, -1, 0),

			int32_3(1, 0, 1),
			int32_3(1, 0, -1),
			int32_3(-1, 0, 1),
			int32_3(-1, 0, -1),

			int32_3(0, 1, 1),
			int32_3(0, 1, -1),
			int32_3(0, -1, 1),
			int32_3(0, -1, -1),


			int32_3(1, 0, 0),
			int32_3(-1, 0, 0),
			int32_3(0, 1, 0),
			int32_3(0, -1, 0),
			int32_3(0, 0, 1),
			int32_3(0, 0, -1),
		};

		fn(data, lut_data, center_cell_idx);
		if (region == 0)
		{
			expand_all()

			for (uint32 i = 0; i < 26; ++i)
			{
				const int32_3 offset = offset_arr[i];
				const int32_3 coord	 = center_cell_idx.xyz + offset;

				const bool x_warp_neg = coord.x < -half;
				const bool x_warp_pos = coord.x >= half;

				const bool y_warp_neg = coord.y < -half;
				const bool y_warp_pos = coord.y >= half;

				const bool z_warp_neg = coord.z < -half;
				const bool z_warp_pos = coord.z >= half;

				if ((x_warp_neg or x_warp_pos) + (y_warp_neg or y_warp_pos) + (z_warp_neg or z_warp_pos) > 1) { continue; }

				int32_4 res;
				if (x_warp_pos)
				{
					res.x = -coord.z - 1;
					res.y = coord.y;
					res.z = 1;
					res.w = 1;
				}
				else if (x_warp_neg)
				{
					res.x = coord.z;
					res.y = coord.y;
					res.z = 1;
					res.w = 2;
				}
				else if (y_warp_pos)
				{
					res.x = coord.x;
					res.y = -coord.z - 1;
					res.z = 1;
					res.w = 3;
				}
				else if (y_warp_neg)
				{
					res.x = coord.x;
					res.y = coord.z;
					res.z = 1;
					res.w = 4;
				}
				else if (z_warp_pos)
				{
					res.x = coord.x;
					res.y = coord.y;
					res.z = 1;
					res.w = 5;
				}
				else if (z_warp_neg)
				{
					res.x = -coord.x - 1;
					res.y = coord.y;
					res.z = 1;
					res.w = 6;
				}
				else
				{
					res.xyz = coord;
					res.w	= 0u;
				}

				fn(data, lut_data, res);
			}
		}
		else
		{
			expand_all()

			for (uint32 i = 0; i < 26; ++i)
			{
				const int32	  layer	 = center_cell_idx.z;
				const int32_3 offset = offset_arr[i];
				const int32_3 coord	 = center_cell_idx.xyz + offset;

				const bool x_warp_neg = coord.x < -half;
				const bool x_warp_pos = coord.x >= half;

				const bool y_warp_neg = coord.y < -half;
				const bool y_warp_pos = coord.y >= half;

				const bool z_warp_neg = offset.z == -1;
				const bool z_warp_pos = offset.z == 1;

				if ((x_warp_neg or x_warp_pos) + (y_warp_neg or y_warp_pos) + (layer == 1 and z_warp_neg) > 1) { continue; }
				if (layer == data.outer_layer_count and z_warp_pos) { continue; }

				int32_4 res;

				res.z = coord.z;
				res.w = center_cell_idx.w;	  // region

				// axis flip => -x-1
				// y = -half -> x = half - 1, y = half - 1 => x = - half
				// y = -x-1
				if (x_warp_pos)
				{
					if (region == 1)
					{
						// x_pos -> z_neg
						res.x = -half;
						res.y = coord.y;
						res.w = 6;
					}
					else if (region == 2)
					{
						// x_neg -> z_pos
						res.x = -half;
						res.y = coord.y;
						res.w = 5;
					}
					else if (region == 3)
					{
						// y_pos -> x_pos
						res.x = coord.y;
						res.y = half - 1;
						res.w = 1;
					}
					else if (region == 4)
					{
						// y_neg -> x_pos
						res.x = -coord.y - 1;
						res.y = -half;
						res.w = 1;
					}
					else if (region == 5)
					{
						// z_pos -> x_pos
						res.x = -half;
						res.y = coord.y;
						res.w = 1;
					}
					else
					{
						// region == 6
						// z_neg -> x_neg
						res.x = -half;
						res.y = coord.y;
						res.w = 2;
					}
				}
				else if (x_warp_neg)
				{
					if (region == 1)
					{
						// x_pos -> z_pos
						res.x = half - 1;
						res.y = coord.y;
						res.w = 5;
					}
					else if (region == 2)
					{
						// x_neg -> z_neg
						res.x = half - 1;
						res.y = coord.y;
						res.w = 6;
					}
					else if (region == 3)
					{
						// y_pos -> x_neg
						res.x = -coord.y - 1;
						res.y = half - 1;
						res.w = 2;
					}
					else if (region == 4)
					{
						// y_neg -> x_neg
						res.x = coord.y;
						res.y = -half;
						res.w = 2;
					}
					else if (region == 5)
					{
						// z_pos -> x_neg
						res.x = half - 1;
						res.y = coord.y;
						res.w = 2;
					}
					else
					{
						// region == 6
						// z_neg -> x_pos
						res.x = half - 1;
						res.y = coord.y;
						res.w = 1;
					}
				}
				else if (y_warp_pos)
				{
					if (region == 1)
					{
						// x_pos -> y_pos
						res.x = half - 1;
						res.y = coord.x;
						res.w = 3;
					}
					else if (region == 2)
					{
						// x_neg -> y_pos
						res.x = -half;
						res.y = -coord.x - 1;
						res.w = 3;
					}
					else if (region == 3)
					{
						// y_pos -> z_neg
						res.x = -coord.x - 1;
						res.y = half - 1;
						res.w = 6;
					}
					else if (region == 4)
					{
						// y_neg -> z_pos
						res.x = coord.x;
						res.y = -half;
						res.w = 5;
					}
					else if (region == 5)
					{
						// z_pos -> y_pos
						res.x = coord.x;
						res.y = -half;
						res.w = 3;
					}
					else
					{
						// region == 6
						// z_neg -> y_pos
						res.x = -coord.x - 1;
						res.y = half - 1;
						res.w = 3;
					}
				}
				else if (y_warp_neg)
				{
					if (region == 1)
					{
						// x_pos -> y_neg
						res.x = half - 1;
						res.y = -coord.x - 1;
						res.w = 4;
					}
					else if (region == 2)
					{
						// x_neg -> y_neg
						res.x = -half;
						res.y = coord.x;
						res.w = 4;
					}
					else if (region == 3)
					{
						// y_pos -> z_pos
						res.x = coord.x;
						res.y = half - 1;
						res.w = 5;
					}
					else if (region == 4)
					{
						// y_neg -> z_neg
						res.x = -coord.x - 1;
						res.y = -half;
						res.w = 6;
					}
					else if (region == 5)
					{
						// z_pos -> y_neg
						res.x = coord.x;
						res.y = half - 1;
						res.w = 4;
					}
					else
					{
						// region == 6
						// z_neg -> y_neg
						res.x = -coord.x - 1;
						res.y = -half;
						res.w = 4;
					}
				}
				else if (layer == 1 and z_warp_neg)
				{
					if (region == 1)
					{
						res.x = half - 1;
						res.y = coord.y;
						res.z = -coord.x - 1;
					}
					else if (region == 2)
					{
						res.x = -half;
						res.y = coord.y;
						res.z = coord.x;
					}
					else if (region == 3)
					{
						res.x = coord.x;
						res.y = half - 1;
						res.z = -coord.y - 1;
					}
					else if (region == 4)
					{
						res.x = coord.x;
						res.y = -half;
						res.z = coord.y;
					}
					else if (region == 5)
					{
						res.x = coord.x;
						res.y = coord.y;
						res.z = half - 1;
					}
					else
					{
						// region == 6
						res.x = -coord.x - 1;
						res.y = coord.y;
						res.z = -half;
					}

					res.w = 0;
				}
				else
				{
					res.xy = coord.xy;
				}

				fn(data, lut_data, res);
			}
		}
	}

	template <bool is_fallback = false>
	float
	calc_tile_surfel_contribution(const gibs_data data, const gibs_tile_surfel surfel, const float3 world_pos, const float3 normal)
	{
		const float	 effective_radius = is_fallback ? surfel.radius * GIBS_SURFEL_OUTER_RADIUS_FACTOR : surfel.radius;
		const float3 rel			  = world_pos - surfel.position;
		const float	 dist_sq		  = dot(rel, rel);

		if (dist_sq > effective_radius * effective_radius) { return 0.f; }

		const float3 surfel_normal = decode_oct_snorm16(surfel.normal_oct_snorm16);

		const float cos_theta = dot(normal, surfel_normal);

		// const float cos_weight = cos_theta > 0.f ? 1.f : 1 + cos_theta;
		// return cos_weight * (1.f - sqrt(dist_sq) / effective_radius);
		if (cos_theta < 0.5f) { return 0.f; }

		// return abs(cos_theta) * (1.f - sqrt(dist_sq) / effective_radius);
		const float distance = sqrt(dist_sq);

		// return 1.f - smoothstep(0.25f * effective_radius, effective_radius, sqrt(dist_sq));
		// return (1.f - sqrt(dist_sq) / effective_radius);
		return smoothstep(0, 1, (1.f - sqrt(dist_sq) / effective_radius));
	}

	// based on ray-tracing-gems ch25
	// https://github.com/Apress/ray-tracing-gems/blob/master/Ch_25_Hybrid_Rendering_for_Real-Time_Ray_Tracing/MultiscaleMeanEstimator.hlsl
	// returns blend factor (catch_up_blend)
	float3
	update_msme(float3 y, inout gibs_surfel_msme msme, float blend_factor = GIBS_MSME_SHORT_WINDOW_BLEND)
	{
		float3 mean_long	 = msme.mean_long;
		float3 mean_short	 = msme.mean_short;
		float3 variance		 = msme.variance;
		float  inconsistency = msme.inconsistency;
		float  vbbr			 = msme.vbbr;

		// Suppress fireflies.
		{
			const float3 dev			 = sqrt(max(1e-5f, variance));
			const float3 high_threshold	 = 0.1f + mean_short + dev * 8.f;
			const float3 overflow		 = max(0.f, y - high_threshold);
			y							-= overflow;
		}

		const float3 delta	= y - mean_short;
		mean_short			= lerp(mean_short, y, blend_factor);
		const float3 delta2 = y - mean_short;

		// This should be a longer window than shortWindowBlend to avoid bias
		// from the variance getting smaller when the short-term mean does.
		const float variance_blend = blend_factor * 0.5f;
		variance				   = lerp(variance, delta * delta2, variance_blend);
		variance				   = max(1e-3, variance);
		const float3 dev		   = sqrt(max(1e-5f, variance));

		const float3 short_diff	   = mean_long - mean_short;
		const float	 relative_diff = dot(float3(0.299f, 0.587f, 0.114f), abs(short_diff) / max(1e-5f, dev));
		inconsistency			   = lerp(inconsistency, relative_diff, 0.08f);

		const float vbbr_target = clamp(dot(float3(0.299f, 0.587f, 0.114f), 0.5f * mean_short / max(1e-5f, dev)), 1.f / 32.f, 1.f);

		float catch_up_blend  = clamp(smoothstep(0.f, 1.f, relative_diff * max(0.02f, inconsistency - 0.2f)), 1.f / 256.f, 1.f);
		catch_up_blend		 *= vbbr;

		vbbr	  = lerp(vbbr, vbbr_target, 0.1f);
		mean_long = lerp(mean_long, y, saturate(catch_up_blend));

		{
			const float incon_a	   = GIBS_MSME_INCON_BLEND;	   // tune
			float		incon_mean = msme.incon_mean;
			float		incon_var  = msme.incon_var;
			const float incon_d	   = inconsistency - incon_mean;
			incon_mean			   = lerp(incon_mean, inconsistency, incon_a);
			const float incon_d2   = inconsistency - incon_mean;
			incon_var			   = lerp(incon_var, incon_d * incon_d2, incon_a);
			msme.incon_mean		   = incon_mean;
			msme.incon_var		   = incon_var;
		}

		// output
		msme.mean_long	   = mean_long;
		msme.mean_short	   = mean_short;
		msme.vbbr		   = vbbr;
		msme.variance	   = variance;
		msme.inconsistency = inconsistency;

		return mean_long;
	}

	float3
	update_msme(float3 y, inout gibs_surfel_probe_msme msme, float blend_factor = GIBS_MSME_SHORT_WINDOW_BLEND)
	{
		float3 mean_long	 = msme.mean_long;
		float3 mean_short	 = msme.mean_short;
		float3 variance		 = msme.variance;
		float  inconsistency = msme.inconsistency;
		float  vbbr			 = msme.vbbr;

		// Suppress fireflies.
		{
			const float3 dev			 = sqrt(max(1e-5f, variance));
			const float3 high_threshold	 = 0.1f + mean_short + dev * 8.f;
			const float3 overflow		 = max(0.f, y - high_threshold);
			y							-= overflow;
		}

		const float3 delta	= y - mean_short;
		mean_short			= lerp(mean_short, y, blend_factor);
		const float3 delta2 = y - mean_short;

		// This should be a longer window than shortWindowBlend to avoid bias
		// from the variance getting smaller when the short-term mean does.
		const float variance_blend = blend_factor * 0.5f;
		variance				   = lerp(variance, delta * delta2, variance_blend);
		variance				   = max(1e-3, variance);
		const float3 dev		   = sqrt(max(1e-5f, variance));

		const float3 short_diff	   = mean_long - mean_short;
		const float	 relative_diff = dot(float3(0.299f, 0.587f, 0.114f), abs(short_diff) / max(1e-5f, dev));
		inconsistency			   = lerp(inconsistency, relative_diff, 0.08f);

		const float vbbr_target = clamp(dot(float3(0.299f, 0.587f, 0.114f), 0.5f * mean_short / max(1e-5f, dev)), 1.f / 32.f, 1.f);

		float catch_up_blend  = clamp(smoothstep(0.f, 1.f, relative_diff * max(0.02f, inconsistency - 0.2f)), 1.f / 256.f, 1.f);
		catch_up_blend		 *= vbbr;

		vbbr	  = lerp(vbbr, vbbr_target, 0.1f);
		mean_long = lerp(mean_long, y, saturate(catch_up_blend));

		// output
		msme.mean_long	   = mean_long;
		msme.mean_short	   = mean_short;
		msme.vbbr		   = vbbr;
		msme.variance	   = variance;
		msme.inconsistency = inconsistency;

		return mean_long;
	}

	template <bool is_tile, typename t_surfel>
	float
	calc_surfel_visibility(const gibs_data data, const uint32 surfel_id, const t_surfel surfel, float3 world_pos, out float2 chebyshev)
	{
		const float3 surfel_normal = decode_oct_snorm16(surfel.normal_oct_snorm16);
		const float3 rel		   = world_pos - surfel.position + surfel_normal * 0.01f;
		const float3 rel_local	   = mul(rel, gen_world_normal_transform(surfel_normal));	 // mul (rel, inv(gen_world_normal_transform_t) )

		float3 dir_local = normalize(rel_local);

		// if (dir_local.y < -0.2f) { return 0.f; }
		if (all(world_pos == surfel.position)) { return 1.f; }

		dir_local.y = max(dir_local.y, epsilon_1e4);
		dir_local	= normalize(dir_local);

		assert(dir_local.y >= 0.f, line);

		const uint32 idx = gibs::calc_atlas_tile_local_idx(dir_local);

		uint16 chebyshev_packed = is_tile ? gibs::tile::visibility_arr(data, surfel_id)[idx] : gibs::cell::visibility_arr(data, surfel_id)[idx];

		chebyshev = float2(unorm8_to_float(uint32_x_to_uint8(chebyshev_packed)), unorm8_to_float(uint32_y_to_uint8(chebyshev_packed)));

		const float dist_norm = saturate(length(rel) / (surfel.radius /* * GIBS_SURFEL_OUTER_RADIUS_FACTOR*/));
		const float mean	  = chebyshev.x;
		const float sq_mean	  = chebyshev.y;

		const float variance = abs(sq_mean - mean * mean);

		if (dist_norm <= mean) { return 1.f; }

		const float k	= dist_norm - mean;
		const float vis = variance / (variance + k * k);	// p(d >= mean + k) <= σ^2 / (σ^2 + k^2)
		return pow_5(vis);
	}

	template <bool is_tile, typename t_surfel>
	float
	calc_surfel_visibility(const gibs_data data, const uint32 surfel_id, const t_surfel surfel, float3 world_pos)
	{
		float2 chebyshev;
		return calc_surfel_visibility<is_tile, t_surfel>(data, surfel_id, surfel, world_pos, chebyshev);
	}

	float3
	sample_screen_irradiance(float2 px, uint32 object_id, float3 world_pos, float3 normal)
	{
		const gibs_data						data				  = load_data();
		byte_array<gibs_tile_surfel_entry>	tile_entry_arr		  = tile::surfel_entry_arr(data);
		byte_array<uint32>					tile_to_surfel_id_arr = tile::tile_to_surfel_id_arr(data);
		structured_buffer<gibs_tile_surfel> surfel_buffer		  = global_resource_buffer[data.h_tile_surfel_buffer_srv_id];

		const uint32				 tile_id	= tile::calc_id(data, uint32_2(px / GIBS_GI_RESOLVE_TILE_SIZE));
		const gibs_tile_surfel_entry tile_entry = tile_entry_arr[tile_id];

		float  max_contribution			  = 0.f;
		uint32 max_contribution_surfel_id = invalid_id_uint32;
		float4 irradiance_sum			  = (float4)0;

		for (uint32 i = 0; i < min(512, tile_entry.surfel_count); ++i)
		{
			const uint32		   surfel_id = tile_to_surfel_id_arr[tile_entry.offset + i];
			const gibs_tile_surfel surfel	 = surfel_buffer[surfel_id];

			const float contribution = gibs::calc_tile_surfel_contribution<false>(data, surfel, world_pos, normal);

			const float3 surfel_irradiance = decode_r11g11b10(surfel.irradiance_r11g11b10);

			assert(is_nan(surfel_irradiance) is_false, line);

			// const float fallback_contribution = gibs_calc_surfel_contribution<true>(data, surfel, world_pos, normal);

			if (surfel.radius < epsilon_1e4 or contribution == 0.f) { continue; }

			// coverage += contribution;
			const float visibility		 = gibs::calc_surfel_visibility<true, gibs_tile_surfel>(data, surfel_id, surfel, world_pos);
			const float contribution_vis = contribution * visibility;

			irradiance_sum += float4(surfel_irradiance, 1.f)
							* contribution_vis
							* smoothstep(0.f, float(GIBS_RADIANCE_CACHE_DELAY), float(surfel.recycle_data.frame_since_born()));

			if (max_contribution < contribution_vis)
			{
				max_contribution		   = contribution_vis;
				max_contribution_surfel_id = surfel_id;
			}
		}

		if (irradiance_sum.w > 0.f)
		{
			irradiance_sum.xyz /= irradiance_sum.w;
			return irradiance_sum.xyz;
		}
		else
		{
			texture_2d<float3> gi_resolve_buffer = global_resource_buffer[data.h_gi_resolve_curr_buffer_srv_id];

			// const float3 col_res = sample_level(gi_resolve_buffer, get_linear_clamp_sampler(), (float2(px) + 0.5f) * inv_backbuffer_size, 0);
			const float3 col_res = gi_resolve_buffer[px];

			attr_branch()

			if ((debug::freeze_spawn_kill(data) is_false) and object_id != invalid_id_uint32)
			{
				const object_data obj = load_object_data(object_id);

				tile::set_surfel_spawn(data,
									   tile_id * GIBS_GI_RESOLVE_SAMPLE_PER_TILE + (GIBS_GI_RESOLVE_SAMPLE_PER_TILE - 1),
									   object_id,
									   rotate_inv(obj.quaternion, world_pos - obj.pos) / obj.scale,
									   encode_oct_snorm16(normalize(rotate_inv(obj.quaternion, normal) * obj.scale)),
									   encode_r11g11b10(col_res));
			}
			return col_res;
		}
	}

	float4
	gather_neighbor_gi(texture_2d<float3> irr_src, texture_2d<uint32_2> geo_src, int32_2 center, float center_z_lin, float3 center_n, int32_2 extent)
	{
		float4 res = zero<float4>();

		const int32_2 r = int32_2(1, 1);

		for (int32 dy = -r.y; dy <= r.y; ++dy)
		{
			for (int32 dx = -r.x; dx <= r.x; ++dx)
			{
				const int32_2  tap			 = clamp(center + int32_2(dx, dy), zero<int32_2>(), extent - 1);
				const uint32_2 geo_tap		 = geo_src[tap];
				const float	   px_depth_tap	 = as_float(geo_tap.x);
				const float3   px_normal_tap = decode_oct_snorm16(geo_tap.y);

				if (geo_tap.x == 0) { continue; }

				const float px_z_lin_tap = calc_linear_z_reversed(cam_near_z, cam_far_z, px_depth_tap);

				const float w = calc_bilateral_weight(center_z_lin, center_n, px_z_lin_tap, px_normal_tap, float2(1.f, 1.f));

				res += float4(irr_src[tap], 1.f) * w;
			}
		}

		return res;
	}
}	 // namespace gibs

namespace gibs
{
	bool
	sample_screen_irradiance(const gibs_data data, const float3 world_pos, const float3 face_normal, out float3 irradiance)
	{
		const float4   clip_pos		= mul(view_proj, float4(world_pos, 1.f));
		const float3   ndc			= clip_pos.xyz / clip_pos.w;
		const float2   screen_pos_f = ndc_xy_to_screen(ndc.xy, backbuffer_size);
		const uint32_2 screen_pos	= uint32_2(screen_pos_f);
		bool		   in_screen	= clip_pos.w > 0.f
							   and all(ndc.xy >= -1.f)
							   and all(ndc.xy <= 1.f)
							   and ndc.z >= 0.f
							   and ndc.z <= 1.f;

		if (in_screen)
		{
			texture_2d<uint32_2> gbuffer		   = global_resource_buffer[opaque_gbuffer_srv_id];
			texture_2d<float>	 depth_buffer	   = global_resource_buffer[opaque_depth_buffer_srv_id];
			texture_2d<float3>	 gi_resolve_buffer = global_resource_buffer[data.h_gi_resolve_curr_buffer_srv_id];
			const float			 z_depth		   = load(depth_buffer, screen_pos);
			const float3		 px_normal		   = decode_oct_snorm16(gbuffer[screen_pos].y);

			in_screen = z_depth != 0.f
					and ndc.z >= (z_depth - epsilon_1e4)	// z_depth + 0.5f - surfel - z_depth - 0.f(far)
					and dot(px_normal, face_normal) > 0.9f;


			if (in_screen)
			{
				// todo, if in screen, skip di
				irradiance = gi_resolve_buffer[screen_pos];

				return true;
			}
		}

		return false;
	}

	float
	calc_near_contribution(float dist, float radius, float3 surfel_normal, float3 normal)
	{
		const float cos_theta = dot(normal, surfel_normal);
		if (cos_theta <= 0.f) { return 0.f; }

		return cos_theta * smoothstep(0, 1, (1.f - dist / radius));
	}

	float
	calc_far_contribution(float3 rel, float3 dir, float3 surfel_normal, float radius, float range, float3 normal)
	{
		const float n_dot_l = dot(normal, dir);

		if (n_dot_l <= 0.f) { return 0.f; }

		const float s_dot_l = dot(surfel_normal, -dir);

		if (s_dot_l <= 0.f) { return 0.f; }

		const float dist_sq = dot(rel, rel);
		const float r_sq	= radius * radius;

		const float range_fade = (1.f - smoothstep(range * 0.75f * range * 0.75f, range * range, dist_sq));

		return n_dot_l * s_dot_l * r_sq / max(dist_sq, r_sq) * range_fade;
	}

	float3
	sample_irradiance(const gibs_data data, const uint32 ray_id, float3 world_pos, float3 normal, uint32 seed)
	{
		const gibs_lut_data lut_data = gibs::load_lut_data();

		float3 irradiance = zero<float3>();

		if (sample_screen_irradiance(data, world_pos, normal, irradiance))
		{
			return irradiance;
		}

		const uint32				cell_id		= gibs::cell::calc_id(data, lut_data, world_pos);
		const gibs_cell_probe_entry probe_entry = gibs::cell::probe_entry_arr(data)[cell_id];

		byte_array<uint32>					 probe_id_arr = gibs::cell::cell_to_probe_id_arr(data);
		structured_buffer<gibs_surfel_probe> probe_buffer = global_resource_buffer[data.h_surfel_probe_buffer_srv_id];

		float4 irradiance_sum = zero<float4>();
		float4 radiance_sum	  = zero<float4>();

		float  max_contribution_near		  = 0.f;
		uint32 max_contribution_near_probe_id = invalid_id_uint32;
		float  max_contribution_far			  = 0.f;
		uint32 max_contribution_far_probe_id  = invalid_id_uint32;

		float surfel_near_coverage_sum = 0.f;
		float surfel_far_coverage_sum  = 0.f;

		for (uint32 i = 0; i < probe_entry.probe_count; ++i)
		{
			const uint32			probe_id	 = probe_id_arr[probe_entry.offset + i];
			const gibs_surfel_probe probe		 = probe_buffer[probe_id];
			const float3			probe_normal = decode_oct_snorm16(probe.normal_oct_snorm16);
			const float				probe_radius = gibs::calc_cell_size(data, lut_data, probe.position);

			const float3 rel	 = probe.position - world_pos;
			const float3 dir	 = normalize(rel);
			const float	 dist_sq = dot(rel, rel);
			const float	 dist	 = sqrt(dist_sq);

			const float sh_depth		= max(0.f, sh1_eval_scalar(probe.depth_sh, -dir));
			const float sh_coverage_far = max(0.f, sh1_eval_scalar(probe.coverage_far_sh, -dir));

			const float visibility = probe_radius * sh_depth > epsilon_1e4
									   ? 1.f - smoothstep(probe_radius * sh_depth, probe_radius * sh_depth * GIBS_PROBE_VIS_FADE_RATIO, dist)
									   : 1.f;

			const float near_contribution = gibs::calc_near_contribution(dist, probe.surfel_radius, probe_normal, normal)
										  * visibility;

			if (near_contribution > 0.f)
			{
				irradiance_sum += float4(decode_r11g11b10(probe.irradiance_r11g11b10), 1.f) * near_contribution;

				surfel_near_coverage_sum += probe.coverage_near * near_contribution;
			}

			const float far_contribution = gibs::calc_far_contribution(rel, dir, probe_normal, probe.surfel_radius, probe_radius, normal)
										 * visibility;

			if (far_contribution > 0.f)
			{
				radiance_sum += float4(decode_r11g11b10(probe.radiance_r11g11b10), 1.f) * far_contribution;

				surfel_far_coverage_sum += sh_coverage_far * far_contribution;
			}


			if (max_contribution_near < near_contribution)
			{
				max_contribution_near_probe_id = probe_id;
				max_contribution_near		   = near_contribution;
			}

			if (max_contribution_far < far_contribution)
			{
				max_contribution_far_probe_id = probe_id;
				max_contribution_far		  = far_contribution;
			}

			if (near_contribution > 0.f or far_contribution > 0.f)
			{
				gibs::cell::set_probe_ref(data, probe_entry.offset + i);
			}
		}

		const float3 irradiance_near = irradiance_sum.w > 0.f ? irradiance_sum.xyz / irradiance_sum.w : zero<float3>();
		const float3 irradiance_far	 = radiance_sum.w > 0.f ? pi * radiance_sum.xyz / radiance_sum.w : zero<float3>();

		const float near_conf = irradiance_sum.w / GIBS_NEAR_CONTRIBUTION_FULL_COVER * GIBS_NEAR_CONTRIBUTION_TRUST_BIAS;
		const float far_conf  = radiance_sum.w / 1.f;

		irradiance = lerp(irradiance_near, irradiance_far, far_conf / (near_conf + far_conf + epsilon_1e4));

		const float probe_near_coverage	 = irradiance_sum.w;
		const float probe_far_coverage	 = radiance_sum.w;
		const float surfel_near_coverage = irradiance_sum.w > 0.f ? surfel_near_coverage_sum / irradiance_sum.w : 0.f;
		const float surfel_far_coverage	 = radiance_sum.w > 0.f ? surfel_far_coverage_sum / radiance_sum.w : 0.f;

		const float3 rng = random_pcg3d(uint32_3(ray_id, seed, frame_index));

		attr_branch()

		if (gibs::debug::freeze_spawn_kill(data) is_false)
		{
			const bool probe_need_spawn = probe_near_coverage < GIBS_SURFEL_PROBE_SPAWN_COVERAGE_NEAR and probe_far_coverage < GIBS_SURFEL_PROBE_SPAWN_COVERAGE_FAR;

			if (probe_need_spawn)
			{
				const float spawn_prob_near = (GIBS_SURFEL_PROBE_SPAWN_COVERAGE_NEAR - probe_near_coverage) / float(GIBS_SURFEL_PROBE_SPAWN_COVERAGE_NEAR);
				const float spawn_prob_far	= (GIBS_SURFEL_PROBE_SPAWN_COVERAGE_FAR - probe_far_coverage) / float(GIBS_SURFEL_PROBE_SPAWN_COVERAGE_FAR);
				const float spawn_prob		= min(spawn_prob_near, spawn_prob_far) * GIBS_SPAWN_PROB_FACTOR;

				if (rng.x < spawn_prob)
				{
					gibs::cell::set_probe_spawn(data, cell_id, spawn_prob, ray_id);
				}
			}
			else if (probe_near_coverage > GIBS_SURFEL_PROBE_KILL_COVERAGE_NEAR or probe_far_coverage > GIBS_SURFEL_PROBE_KILL_COVERAGE_FAR)
			{
				const float kill_prob_near = (probe_near_coverage - GIBS_SURFEL_PROBE_KILL_COVERAGE_NEAR) / float(GIBS_SURFEL_PROBE_KILL_COVERAGE_NEAR);
				const float kill_prob_far  = (probe_far_coverage - GIBS_SURFEL_PROBE_KILL_COVERAGE_FAR) / float(GIBS_SURFEL_PROBE_KILL_COVERAGE_FAR);
				const float kill_prob	   = max(kill_prob_near, kill_prob_far) * GIBS_KILL_PROB_FACTOR;

				const uint32 kill_probe_id = kill_prob_near > kill_prob_far ? max_contribution_near_probe_id : max_contribution_far_probe_id;

				if (rng.y < kill_prob)
				{
					gibs::cell::set_probe_kill(data, cell_id, kill_prob, kill_probe_id);
				}
			}

			if (probe_need_spawn is_false and surfel_near_coverage < GIBS_CELL_SURFEL_SPAWN_COVERAGE_NEAR and surfel_far_coverage < GIBS_CELL_SURFEL_SPAWN_COVERAGE_FAR)
			{
				const float spawn_prob_near = (GIBS_CELL_SURFEL_SPAWN_COVERAGE_NEAR - surfel_near_coverage) / float(GIBS_CELL_SURFEL_SPAWN_COVERAGE_NEAR);
				const float spawn_prob_far	= (GIBS_CELL_SURFEL_SPAWN_COVERAGE_FAR - surfel_far_coverage) / float(GIBS_CELL_SURFEL_SPAWN_COVERAGE_FAR);
				const float spawn_prob		= min(spawn_prob_near, spawn_prob_far) * GIBS_SPAWN_PROB_FACTOR;

				if (rng.z < spawn_prob)
				{
					gibs::cell::set_surfel_spawn(data, cell_id, spawn_prob, ray_id);
				}
			}
		}


		return irradiance;
	}

	float4
	sample_irradiance(const gibs_data data, float3 world_pos, float3 normal)
	{
		const gibs_lut_data lut_data = gibs::load_lut_data();

		const uint32				cell_id		= gibs::cell::calc_id(data, lut_data, world_pos);
		const gibs_cell_probe_entry probe_entry = gibs::cell::probe_entry_arr(data)[cell_id];

		byte_array<uint32>					 probe_id_arr = gibs::cell::cell_to_probe_id_arr(data);
		structured_buffer<gibs_surfel_probe> probe_buffer = global_resource_buffer[data.h_surfel_probe_buffer_srv_id];

		float4 irradiance_sum = zero<float4>();
		float4 radiance_sum	  = zero<float4>();

		float surfel_near_coverage_sum = 0.f;
		float surfel_far_coverage_sum  = 0.f;

		for (uint32 i = 0; i < probe_entry.probe_count; ++i)
		{
			const uint32			probe_id	 = probe_id_arr[probe_entry.offset + i];
			const gibs_surfel_probe probe		 = probe_buffer[probe_id];
			const float3			probe_normal = decode_oct_snorm16(probe.normal_oct_snorm16);
			const float				probe_radius = gibs::calc_cell_size(data, lut_data, probe.position);

			const float3 rel	 = probe.position - world_pos;
			const float3 dir	 = normalize(rel);
			const float	 dist_sq = dot(rel, rel);
			const float	 dist	 = sqrt(dist_sq);

			const float sh_depth		= max(0.f, sh1_eval_scalar(probe.depth_sh, -dir));
			const float sh_coverage_far = max(0.f, sh1_eval_scalar(probe.coverage_far_sh, -dir));

			const float visibility = probe_radius * sh_depth > epsilon_1e4
									   ? 1.f - smoothstep(probe_radius * sh_depth, probe_radius * sh_depth * GIBS_PROBE_VIS_FADE_RATIO, dist)
									   : 1.f;

			const float near_contribution = gibs::calc_near_contribution(dist, probe.surfel_radius, probe_normal, normal)
										  * visibility;

			if (near_contribution > 0.f)
			{
				irradiance_sum += float4(decode_r11g11b10(probe.irradiance_r11g11b10), 1.f) * near_contribution;

				surfel_near_coverage_sum += probe.coverage_near * near_contribution;
			}

			const float far_contribution = gibs::calc_far_contribution(rel, dir, probe_normal, probe.surfel_radius, probe_radius, normal)
										 * visibility;

			if (far_contribution > 0.f)
			{
				radiance_sum += float4(decode_r11g11b10(probe.radiance_r11g11b10), 1.f) * far_contribution;

				surfel_far_coverage_sum += sh_coverage_far * far_contribution;
			}
		}

		const float3 irradiance_near = irradiance_sum.w > 0.f ? irradiance_sum.xyz / irradiance_sum.w : zero<float3>();
		const float3 irradiance_far	 = radiance_sum.w > 0.f ? pi * radiance_sum.xyz / radiance_sum.w : zero<float3>();

		const float near_conf = irradiance_sum.w / GIBS_NEAR_CONTRIBUTION_FULL_COVER * GIBS_NEAR_CONTRIBUTION_TRUST_BIAS;
		const float far_conf  = radiance_sum.w / 1.f;

		const float3 irradiance = lerp(irradiance_near, irradiance_far, far_conf / (near_conf + far_conf + epsilon_1e4));

		return float4(irradiance, near_conf + far_conf);
	}
}	 // namespace gibs