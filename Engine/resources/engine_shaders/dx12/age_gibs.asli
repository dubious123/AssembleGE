		store_ray_entry(const gibs_data data, uint32 id, gibs_ray_entry entry)
		{
			rw_byte_address_buffer buf = global_resource_buffer[data.h_ray_entry_buffer_uav_id];

			store<gibs_ray_entry>(buf, data.ray_entry_buffer_offset() + sizeof(gibs_ray_entry) * id, entry);
		}

