// debug
namespace gibs
{
	namespace debug
	{
		bool
		freeze_spawn_kill(const gibs_data data)
		{
			return data.debug_flags & GIBS_DEBUG_FLAGS_FREEZE_SPAWN;
		}
	}	 // namespace debug


}	 // namespace gibs

// indirect arg
namespace gibs
{
	namespace indirect_arg
	{
#define gibs_indirect_arg_func(name, nth)                                                       \
	void                                                                                        \
	name(const gibs_data data, uint32_3 arg)                                                    \
	{                                                                                           \
		rw_byte_address_buffer buf = global_resource_buffer[data.h_indirect_arg_buffer_uav_id]; \
		store(buf, sizeof(uint32_3) * nth, arg);                                                \
	}
		gibs_indirect_arg_func(set_update_tile_surfel_id_stack, 0);
		gibs_indirect_arg_func(set_update_cell_surfel_id_stack, 1);
		gibs_indirect_arg_func(set_update_surfel_probe_id_stack, 2);
		gibs_indirect_arg_func(set_update_cell_surfel, 3);
		gibs_indirect_arg_func(set_update_surfel_probe, 4);
		gibs_indirect_arg_func(set_alloc_tile_surfel, 5);
		gibs_indirect_arg_func(set_alloc_cell_surfel, 6);
		gibs_indirect_arg_func(set_alloc_surfel_probe, 7);
		gibs_indirect_arg_func(set_tile_surfel_ideal_ray_count_reduce, 8);
		gibs_indirect_arg_func(set_cell_surfel_ideal_ray_count_reduce, 9);
		gibs_indirect_arg_func(set_tile_surfel_ray_count_prefix, 10);
		gibs_indirect_arg_func(set_cell_surfel_ray_count_prefix, 11);
		gibs_indirect_arg_func(set_ray_entry, 12);
		gibs_indirect_arg_func(set_tile_surfel_scatter, 13);
		gibs_indirect_arg_func(set_cell_surfel_scatter, 14);
		gibs_indirect_arg_func(set_surfel_probe_scatter, 15);
		gibs_indirect_arg_func(set_surfel_probe_gather, 16);
		gibs_indirect_arg_func(set_ray_trace, 17);
		gibs_indirect_arg_func(set_ray_resolve, 18);
		gibs_indirect_arg_func(set_ray_integrate, 19);
		gibs_indirect_arg_func(set_build_cdf, 20);

#undef gibs_indirect_arg_func
	}	 // namespace indirect_arg


}	 // namespace gibs

//---[ surfel ]------------------------------------------------------------------------------------------------------

namespace gibs
{
	void
	set_cell_surfel_ref(const gibs_data data, uint32 surfel_id)
	{
		rw_structured_buffer<gibs_cell_surfel> buf = global_resource_buffer[data.h_cell_surfel_buffer_uav_id];

		gibs_cell_surfel surfel = buf[surfel_id];
		surfel.recycle_data.set_ref();
		buf[surfel_id] = surfel;
	}

	void
	set_probe_ref(const gibs_data data, uint32 probe_id)
	{
		rw_structured_buffer<gibs_recycle_data> probe_recycle_buffer = global_resource_buffer[data.h_surfel_probe_recycle_buffer_uav_id];

		gibs_recycle_data recycle_data = probe_recycle_buffer[probe_id];
		recycle_data.set_ref();
		probe_recycle_buffer[probe_id] = recycle_data;
	}
}	 // namespace gibs

// cell
namespace gibs
{
	namespace cell
	{
		uint32
		allocated_surfel_count(const gibs_data data)
		{
			byte_address_buffer buf = global_resource_buffer[data.h_cell_buffer_srv_id];
			return load<uint32>(buf, data.cell_surfel_count_offset());
		}

		uint32
