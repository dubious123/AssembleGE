		bool
		add_surfel(const gibs_data data, uint32 tile_id)
		{
			rw_byte_array<gibs_tile_surfel_entry> arr = gibs::tile::surfel_entry_rw_arr(data);

			const uint32 count_original = arr.atomic_inc(tile_id, 1u, 1u);

			return count_original < data.tile_to_surfel_id_capacity();
		}

		void
		set_tile_to_surfel_id(const gibs_data data, uint32 tile_id, uint32 surfel_id)
		{
			rw_byte_array<gibs_tile_surfel_entry> entry_arr = gibs::tile::surfel_entry_rw_arr(data);
			const gibs_tile_surfel_entry		  entry		= entry_arr[tile_id];

			const uint32 local_offset = entry_arr.atomic_inc(tile_id, 1u, 1u);

			tile_to_surfel_id_rw_arr(data).store(entry.offset + local_offset, surfel_id);
		}

		uint32
		calc_id(const gibs_data data, uint32_2 tile_idx)
		{
			return tile_idx.y * data.tile_count_w + tile_idx.x;
		}

		void
		set_surfel_spawn(const gibs_data data, uint32 tile_sample_id, uint32 object_id, float3 local_pos, uint32 local_normal_oct_snorm16, uint32 irradiance_packed)
		{
			rw_byte_address_buffer buf = global_resource_buffer[data.h_tile_spawn_kill_buffer_uav_id];

			const uint32 offset = data.tile_spawn_kill_data_offset(tile_sample_id);

			uint32 original;
			buf_interlocked_compare_exchange(buf, offset, invalid_id_uint32, object_id, original);

			if (original == invalid_id_uint32)
			{
				store<float3>(buf, offset + sizeof(object_id), local_pos);
				store<uint32>(buf, offset + sizeof(object_id) + sizeof(local_pos), local_normal_oct_snorm16);
				store<uint32>(buf, offset + sizeof(object_id) + sizeof(local_pos) + sizeof(local_normal_oct_snorm16), irradiance_packed);
			}
		}

		void
		set_surfel_kill(const gibs_data data, uint32 tile_sample_id, uint32 surfel_id)
		{
			rw_byte_address_buffer buf = global_resource_buffer[data.h_tile_spawn_kill_buffer_uav_id];

			const uint32 offset = data.tile_spawn_kill_data_offset(tile_sample_id) + sizeof(uint32) + sizeof(float3) + sizeof(uint32) + sizeof(uint32);

			uint32 original;
			buf_interlocked_compare_exchange(buf, offset, invalid_id_uint32, surfel_id, original);
		}

		gibs_tile_surfel_spawn_kill_data
		load_surfel_spawn_kill_data(const gibs_data data, uint32 tile_sample_id)
		{
			byte_address_buffer buf = global_resource_buffer[data.h_tile_spawn_kill_buffer_srv_id];
			return load<gibs_tile_surfel_spawn_kill_data>(buf, data.tile_spawn_kill_data_offset(tile_sample_id));
		}

