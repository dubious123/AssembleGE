//---[ cell spawn kill ]---
void
gibs_set_cell_surfel_spawn(const gibs_data data, uint32 cell_idx_flat, uint32 object_id, float3 local_pos, uint32 local_normal_oct_snorm16, uint32 radiance_packed)
{
	rw_byte_address_buffer buf = global_resource_buffer[data.h_cell_spawn_kill_buffer_uav_id];

	const uint32 offset = data.cell_spawn_kill_data_offset(cell_idx_flat);

	uint32 original;
	buf_interlocked_compare_exchange(buf, offset, invalid_id_uint32, object_id, original);

	if (original == invalid_id_uint32)
	{
		store<float3>(buf, offset + sizeof(object_id), local_pos);
		store<uint32>(buf, offset + sizeof(object_id) + sizeof(local_pos), local_normal_oct_snorm16);
		store<uint32>(buf, offset + sizeof(object_id) + sizeof(local_pos) + sizeof(local_normal_oct_snorm16), radiance_packed);
	}
}

void
gibs_set_cell_surfel_kill(const gibs_data data, uint32 cell_idx_flat, uint32 surfel_id)
{
	rw_byte_address_buffer buf = global_resource_buffer[data.h_cell_spawn_kill_buffer_uav_id];

	const uint32 offset = data.cell_spawn_kill_data_offset(cell_idx_flat) + sizeof(gibs_cell_surfel_spawn_data);

	uint32 original;
	buf_interlocked_compare_exchange(buf, offset, invalid_id_uint32, surfel_id, original);
}

gibs_cell_surfel_spawn_kill_data
gibs_load_cell_surfel_spawn_kill_data(const gibs_data data, uint32 cell_idx_flat)
{
	byte_address_buffer buf = global_resource_buffer[data.h_cell_spawn_kill_buffer_srv_id];
	return load<gibs_cell_surfel_spawn_kill_data>(buf, data.cell_spawn_kill_data_offset(cell_idx_flat));
}

// cell_to_surfel[slot_idx] = surfel_id
void
gibs_set_cell_surfel_ref(const gibs_data data, uint32 slot_idx)
{
	rw_byte_address_buffer buf = global_resource_buffer[data.h_cell_spawn_kill_buffer_uav_id];

	const uint32 offset = data.cell_surfel_ref_word_offset(slot_idx);
	const uint32 flag	= 1u << (slot_idx % 32u);

	buf_interlocked_and(buf, offset, ~flag);
}

bool
gibs_get_cell_surfel_ref(const gibs_data data, uint32 slot_idx)
{
	byte_address_buffer buf = global_resource_buffer[data.h_cell_spawn_kill_buffer_srv_id];

	const uint32 offset = data.cell_surfel_ref_word_offset(slot_idx);
	const uint32 flag	= 1u << (slot_idx % 32u);

	return (~load<uint32>(buf, offset)) & flag;
}

uint32
gibs_get_cell_surfel_ref_word(const gibs_data data, uint32 world_idx)
{
	byte_address_buffer buf = global_resource_buffer[data.h_cell_spawn_kill_buffer_srv_id];

	return load<uint32>(buf, data.cell_surfel_ref_offset() + sizeof(uint32) * world_idx);
}

