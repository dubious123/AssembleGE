void
gibs_store_ray_entry(const gibs_data data, uint32 idx, const gibs_ray_entry entry)
{
	assert(idx < GIBS_RAY_BUDGET, g::fmt_gibs, line);
	static_assert(sizeof(gibs_ray_entry) <= sizeof(gibs_ray_result));
	rw_byte_address_buffer buf = global_resource_buffer[data.h_ray_buffer_uav_id];
	store<gibs_ray_entry>(buf, data.ray_entry_offset(idx), entry);
}

gibs_ray_entry
gibs_load_ray_entry_rw(const gibs_data data, uint32 idx)
{
	assert(idx < GIBS_RAY_BUDGET, g::fmt_gibs, line);
	static_assert(sizeof(gibs_ray_entry) <= sizeof(gibs_ray_result));
	rw_byte_address_buffer buf = global_resource_buffer[data.h_ray_buffer_uav_id];
	return load<gibs_ray_entry>(buf, data.ray_entry_offset(idx));
}

