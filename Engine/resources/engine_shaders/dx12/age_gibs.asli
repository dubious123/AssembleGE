		int32_4
		calc_idx(const gibs_data data, const gibs_lut_data lut_data, const float3 world_pos)
		{
			const uint32 layer = calc_layer(data, lut_data, world_pos);

			const float3 rel = world_pos - calc_cell_origin(lut_data);

			const int32 half = data.cell_count >> 1u;

			int32 region = 0;

			if (layer == 0)
			{
				const float3 cell_idx_float = floor(rel / lut_data.cell_size_arr[0]);

				return int32_4(clamp(int32_3(cell_idx_float), -half, half - 1), region);
			}

			const float3 region_xyz = calc_region(rel, region);

			const float	 cell_size_xy	   = region_xyz.z * 2.f / data.cell_count;
			const float2 cell_idx_float_xy = floor(region_xyz.xy / cell_size_xy);

			return int32_4(clamp(int32_2(cell_idx_float_xy), -half, half - 1), layer, region);
		}

		uint32
		calc_id(const gibs_data data, int32_4 cell_idx)
		{
			const int32 region = cell_idx.w;
			if (region == 0)
			{
				uint32_3 cell_idx_uint32 = cell_idx.xyz + (data.cell_count >> 1);

				return cell_idx_uint32.x
					 + cell_idx_uint32.y * data.cell_count
					 + cell_idx_uint32.z * data.cell_count * data.cell_count;
			}

			// layer >= 1
			const uint32 layer = cell_idx.z;

			const uint32 base_offset = data.cell_count * data.cell_count * data.cell_count
									 + 6 * data.cell_count * data.cell_count * (layer - 1)
									 + (region - 1) * data.cell_count * data.cell_count;

			const int32_2 cell_idx_xy = cell_idx.xy + int32(data.cell_count >> 1);
			assert(all(cell_idx_xy >= 0), line);


			const uint32 res = base_offset
							 + cell_idx_xy.x
							 + cell_idx_xy.y * data.cell_count;

			assert(res < data.cell_count_total, line);
			return res;
		}

		uint32
		calc_id(const gibs_data data, const gibs_lut_data lut_data, const float3 world_pos)
		{
			return calc_id(data, calc_idx(data, lut_data, world_pos));
		}

		// cell_to_surfel[local_offset] = surfel_id


		void
		set_probe_ref(const gibs_data data, uint32 local_offset)
		{
			rw_byte_address_buffer buf = global_resource_buffer[data.h_cell_spawn_kill_buffer_uav_id];

			const uint32 offset = data.cell_probe_ref_word_offset(local_offset);
			const uint32 flag	= 1u << (local_offset % 32u);

			buf_interlocked_and(buf, offset, ~flag);
		}

		bool
		get_probe_ref(const gibs_data data, uint32 local_offset)
		{
			byte_address_buffer buf = global_resource_buffer[data.h_cell_spawn_kill_buffer_srv_id];

			const uint32 offset = data.cell_probe_ref_word_offset(local_offset);
			const uint32 flag	= 1u << (local_offset % 32u);

			return (~load<uint32>(buf, offset)) & flag;
		}

		uint32
		get_probe_ref_word(const gibs_data data, uint32 word_idx)
		{
			byte_address_buffer buf = global_resource_buffer[data.h_cell_spawn_kill_buffer_srv_id];

			return load<uint32>(buf, data.cell_probe_ref_offset() + sizeof(uint32) * word_idx);
		}

