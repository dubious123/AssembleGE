	namespace ray
	{
		void
		reset_alloc(const gibs_data data)
		{
			atomic_counter::init(global_resource_buffer[data.h_ray_entry_buffer_uav_id], data.tile_surfel_ray_count_total_offset()).set(0u);
			atomic_counter::init(global_resource_buffer[data.h_ray_entry_buffer_uav_id], data.cell_surfel_ray_count_total_offset()).set(0u);
		}

