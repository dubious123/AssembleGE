//---[ gibs data ]------------------------------------------------------------------------------------------------------
gibs_data
gibs_load_gibs_data()
{
	return load<gibs_data>(static_buffer, GIBS_DATA_OFFSET);
}

gibs_lut_data
gibs_load_gibs_lut_data()
{
	return load<gibs_lut_data>(static_buffer, GIBS_LUT_DATA_OFFSET);
}

bool
gibs_enabled()
{
	return ddgi_enabled_and_extra & 2;
}

//---[ gibs indirect arg ]------------------------------------------------------------------------------------------------------
#define gibs_indirect_arg_func(name, nth)                                                       \
	void                                                                                        \
	name(const gibs_data data, uint32_3 arg)                                                    \
	{                                                                                           \
		rw_byte_address_buffer buf = global_resource_buffer[data.h_indirect_arg_buffer_uav_id]; \
		store(buf, sizeof(uint32_3) * nth, arg);                                                \
	}
gibs_indirect_arg_func(gibs_set_indirect_arg_surfel_update, 0);
gibs_indirect_arg_func(gibs_set_indirect_arg_ray_ideal_count_sum, 1);
gibs_indirect_arg_func(gibs_set_indirect_arg_ray_count_prefix, 2);
gibs_indirect_arg_func(gibs_set_indirect_arg_ray_entry, 3);
gibs_indirect_arg_func(gibs_set_indirect_arg_surfel_scatter, 4);
gibs_indirect_arg_func(gibs_set_indirect_arg_ray_trace, 5);
gibs_indirect_arg_func(gibs_set_indirect_arg_ray_integrate, 6);
gibs_indirect_arg_func(gibs_set_indirect_arg_build_cdf, 7);
gibs_indirect_arg_func(gibs_set_indirect_arg_radiance_sharing, 8);

#undef gibs_indirect_arg_func

//---[ surfel ]------------------------------------------------------------------------------------------------------
uint32
gibs_calc_tile_local_idx(const float3 local_dir)
{
	assert(local_dir.y >= 0.f, g::fmt_gibs, line);
	const float2 oct_uv = encode_world_hemi_octahedral(local_dir);							// [-1, 1]
	int32_2		 idx	= int32_2(floor((oct_uv * 0.5f + 0.5f) * GIBS_ATLAS_TILE_SIZE));	// [0, 6)
	idx					= min(idx, GIBS_ATLAS_TILE_SIZE - 1);
	return idx.x + idx.y * GIBS_ATLAS_TILE_SIZE;
}

byte_array<surfel>
gibs_load_surfel_arr(const gibs_data data)
{
	return byte_array<surfel>::init(global_resource_buffer[data.h_surfel_buffer_srv_id], data.surfel_offset(), data.max_surfel_count);
}

rw_byte_array<surfel>
gibs_load_surfel_rw_arr(const gibs_data data)
{
	return rw_byte_array<surfel>::init(global_resource_buffer[data.h_surfel_buffer_uav_id], data.surfel_offset(), data.max_surfel_count);
}

void
gibs_set_surfel_ref(const gibs_data data, uint32 surfel_id)
{
	rw_byte_address_buffer buf			= global_resource_buffer[data.h_surfel_buffer_uav_id];
	const uint32		   offset		= data.surfel_offset() + sizeof(surfel) * surfel_id + (sizeof(float3) + sizeof(uint32) + sizeof(uint32) + sizeof(half));
	const uint16		   recycle_data = load<uint16>(buf, offset) & 0x80ff;
	store<uint16>(buf, offset, recycle_data);
}

