		void
		set_probe_spawn(const gibs_data data, uint32 cell_id, float spawn_prob, uint32 ray_id)
		{
			rw_byte_address_buffer buf = global_resource_buffer[data.h_cell_spawn_kill_buffer_uav_id];

			buf_interlocked_min(buf, data.cell_probe_spawn_data_offset() + sizeof(uint64) * cell_id, (uint64(~as_uint(spawn_prob)) << 32u) | ray_id);
		}

