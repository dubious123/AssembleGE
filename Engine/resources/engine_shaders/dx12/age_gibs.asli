		void
		atomic_add_ideal_ray_count(const gibs_data data, uint32 ray_count)
		{
			atomic_counter counter = atomic_counter::init(global_resource_buffer[data.h_scratch_buffer_uav_id], data.tile_surfel_ideal_ray_count_total_offset());
			counter.inc(ray_count);
		}

		uint32
		ideal_ray_count_total(const gibs_data data)
		{
			return atomic_counter::init(global_resource_buffer[data.h_scratch_buffer_uav_id], data.tile_surfel_ideal_ray_count_total_offset()).value();
		}

		uint32
		alloc_ray(const gibs_data data, uint32 ray_count)
		{
			return ray_count_total_atomic_counter(data).inc(ray_count);
		}

		uint32
		ray_count_total(const gibs_data data)
		{
			byte_address_buffer buf = global_resource_buffer[data.h_ray_entry_buffer_srv_id];
			return load<uint32>(buf, data.tile_surfel_ray_count_total_offset());
		}
	}	 // namespace tile

