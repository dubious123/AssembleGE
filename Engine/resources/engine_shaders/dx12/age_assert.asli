	arg_header arg_header_7 = arg_header_init(arg7);
	arg_header arg_header_8 = arg_header_init(arg8);
	arg_header arg_header_9 = arg_header_init(arg9);

	debug_printer printer = debug_printer::init(
		debug_assert_buffer, n + 1, 10,
		arg_header_0.arg_byte_size + arg_header_1.arg_byte_size
			+ arg_header_2.arg_byte_size + arg_header_3.arg_byte_size
			+ arg_header_4.arg_byte_size + arg_header_5.arg_byte_size
			+ arg_header_6.arg_byte_size + arg_header_7.arg_byte_size
			+ arg_header_8.arg_byte_size + arg_header_9.arg_byte_size);

	if (printer.valid is_false) { return; }

	for (uint32 i = 0; i < n; ++i)
	{
		printer.append_char(fmt[i]);
	}

	printer.append_char(0);

	printer.flush_char();

	printer.append_arg_header(arg_header_0);
	printer.append_arg(arg0);
	printer.append_arg_header(arg_header_1);
	printer.append_arg(arg1);
	printer.append_arg_header(arg_header_2);
	printer.append_arg(arg2);
	printer.append_arg_header(arg_header_3);
	printer.append_arg(arg3);
	printer.append_arg_header(arg_header_4);
	printer.append_arg(arg4);
	printer.append_arg_header(arg_header_5);
	printer.append_arg(arg5);
	printer.append_arg_header(arg_header_6);
	printer.append_arg(arg6);
	printer.append_arg_header(arg_header_7);
	printer.append_arg(arg7);
	printer.append_arg_header(arg_header_8);
	printer.append_arg(arg8);
	printer.append_arg_header(arg_header_9);
	printer.append_arg(arg9);
}

void
assert(bool test)
{
#if enable_debug_assert
	if (test is_false)
	{
		debug_log(g::fmt_default_assert_0, g::default_shader_file_name);
	}
#endif
}

