rw_byte_address_buffer debug_assert_buffer reg(u666, space666);

#define static_assert(expr) _Static_assert(expr, #expr)

template <uint32 n>
arg_header
arg_header_init(uint32 arg[n])
{
	arg_header res;
	res.arg_type	  = DEBUG_ARG_TYPE_STRING;
	res.arg_byte_size = align_up(n + 1, sizeof(uint32));
	return res;
}

#define DEF_ARG_HEADER_INIT(type_name, type_enum)       \
	arg_header                                          \
	arg_header_init(type_name arg)                      \
	{                                                   \
		arg_header res;                                 \
		res.arg_type	  = DEBUG_ARG_TYPE_##type_enum; \
		res.arg_byte_size = sizeof(type_name);          \
		return res;                                     \
	}

DEF_ARG_HEADER_INIT(uint64, UINT64)
DEF_ARG_HEADER_INIT(uint32, UINT32)

DEF_ARG_HEADER_INIT(int64, INT64)
DEF_ARG_HEADER_INIT(int32, INT32)

DEF_ARG_HEADER_INIT(float, FLOAT)

DEF_ARG_HEADER_INIT(int32_2, INT32_2)
DEF_ARG_HEADER_INIT(int32_3, INT32_3)
DEF_ARG_HEADER_INIT(int32_4, INT32_4)

DEF_ARG_HEADER_INIT(uint32_2, UINT32_2)
DEF_ARG_HEADER_INIT(uint32_3, UINT32_3)
DEF_ARG_HEADER_INIT(uint32_4, UINT32_4)

DEF_ARG_HEADER_INIT(float2, FLOAT2)
DEF_ARG_HEADER_INIT(float3, FLOAT3)
DEF_ARG_HEADER_INIT(float4, FLOAT4)

// DEF_ARG_HEADER_INIT(float2x2, FLOAT2X2)
// DEF_ARG_HEADER_INIT(float2x3, FLOAT2X3)
// DEF_ARG_HEADER_INIT(float2x4, FLOAT2X4)

// DEF_ARG_HEADER_INIT(float3x2, FLOAT3X2)
DEF_ARG_HEADER_INIT(float3x3, FLOAT3X3)
DEF_ARG_HEADER_INIT(float3x4, FLOAT3X4)

// DEF_ARG_HEADER_INIT(float4x2, FLOAT4X2)
// DEF_ARG_HEADER_INIT(float4x3, FLOAT4X3)
DEF_ARG_HEADER_INIT(float4x4, FLOAT4X4)


#undef DEF_ARG_HEADER_INIT

struct debug_printer
{
	rw_byte_address_buffer buf;

	uint32 offset;

	uint32 i;
	bool   valid;

	uint32 char_packed;

	static debug_printer
	init(rw_byte_address_buffer buf, uint32 msg_len, uint32 arg_count, uint32 arg_byte_size_total)
	{
		debug_printer res;
		res.buf = buf;

		const uint32 alloc_byte_size = sizeof(msg_header)
									 + sizeof(arg_header) * arg_count
									 + align_up(msg_len, sizeof(uint32))
									 + align_up(arg_byte_size_total, sizeof(uint32));

		buf_interlocked_add(buf, 0u, 1u);
		buf_interlocked_add(buf, 4u, alloc_byte_size, res.offset);

		res.offset		+= sizeof(uint32) * 2;
		res.i			 = 0;
		res.char_packed	 = 0;

		if (res.offset + alloc_byte_size <= DEBUG_ASSERT_BUFFER_BYTE_SIZE)
		{
			res.valid = true;

			msg_header header;
			header.fmt_char_count  = msg_len;
			header.arg_count	   = arg_count;
			header.byte_size_total = alloc_byte_size;
			store<msg_header>(buf, res.offset, header);

			res.offset += sizeof(msg_header);
		}
		else
		{
			buf_interlocked_add(buf, 0u, int32(-1));
			buf_interlocked_add(buf, 4u, int32(-alloc_byte_size));
			res.valid = false;
		}

		return res;
	}

	bool
	is_valid()
	{
		return valid;
	}

	void
	flush_char()
	{
		if (i == 0) { return; }

		buf.Store<uint32>(offset, char_packed);
		offset		+= sizeof(uint32);
		char_packed	 = 0u;

		i = 0;
	}

	void
	append_char(uint32 value)
	{
		char_packed |= (value & 0xff) << (i * 8);

		if (++i == 4)
		{
			flush_char();
		}
	}

	void
	append_arg_header(arg_header header)
	{
		store(buf, offset, header);
		offset += sizeof(header);
	}

#define def_append_arg(type_name) \
	void                          \
	append_arg(in type_name arg)  \
	{                             \
		store(buf, offset, arg);  \
		offset += sizeof(arg);    \
	}
	def_append_arg(uint64);
	def_append_arg(uint32);
	def_append_arg(int64);
	def_append_arg(int32);
	def_append_arg(float);
	def_append_arg(int32_2);
	def_append_arg(int32_3);
	def_append_arg(int32_4);
	def_append_arg(uint32_2);
	def_append_arg(uint32_3);
	def_append_arg(uint32_4);
	def_append_arg(float2);
	def_append_arg(float3);
	def_append_arg(float4);
	def_append_arg(float2x2);
	def_append_arg(float3x3);
	def_append_arg(float3x4);
	def_append_arg(float4x4);

#undef def_append_arg

	template <uint32 n>
	void
	append_arg(uint32 str[n])
	{
		for (uint32 i = 0; i < n; ++i)
		{
			append_char(str[i]);
		}

		append_char(0);

		flush_char();
	}
};

template <uint32 n>
void
debug_log(const uint32 fmt[n])
{
	debug_printer printer = debug_printer::init(debug_assert_buffer, n + 1, 0, 0);

	if (printer.valid is_false) { return; }

	for (uint32 i = 0; i < n; ++i)
	{
		printer.append_char(fmt[i]);
	}

	printer.append_char(0);

	printer.flush_char();
}

template <uint32 n, typename t0>
void
debug_log(const uint32 fmt[n], t0 arg0)
{
	arg_header arg_header_0 = arg_header_init(arg0);

	debug_printer printer = debug_printer::init(debug_assert_buffer, n + 1, 1, arg_header_0.arg_byte_size);

	if (printer.valid is_false) { return; }

	for (uint32 i = 0; i < n; ++i)
	{
		printer.append_char(fmt[i]);
	}

	printer.append_char(0);

	printer.flush_char();

	printer.append_arg_header(arg_header_0);
	printer.append_arg(arg0);
}

template <uint32 n, typename t0, typename t1>
void
debug_log(const uint32 fmt[n], t0 arg0, t1 arg1)
{
	arg_header arg_header_0 = arg_header_init(arg0);
	arg_header arg_header_1 = arg_header_init(arg1);

	debug_printer printer = debug_printer::init(
		debug_assert_buffer, n + 1, 2,
		arg_header_0.arg_byte_size + arg_header_1.arg_byte_size);

	if (printer.valid is_false) { return; }

	for (uint32 i = 0; i < n; ++i)
