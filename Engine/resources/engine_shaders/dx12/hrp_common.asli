uint32
world_to_bin_x(float world_x)
{
	float bin_f = (world_x - light_bin_origin.x) * light_bin_cell_size_inv.x;
	return uint32(clamp(bin_f, 0.f, X_SLICE_COUNT - 1.f));
}

uint32
world_to_bin_y(float world_y)
{
	float bin_f = (world_y - light_bin_origin.y) * light_bin_cell_size_inv.y;
	return uint32(clamp(bin_f, 0.f, Y_SLICE_COUNT - 1.f));
}

uint32
world_to_bin_z(float world_z)
{
	float bin_f = (world_z - light_bin_origin.z) * light_bin_cell_size_inv.z;
	return uint32(clamp(bin_f, 0.f, Z_SLICE_COUNT - 1.f));
}

uint32_3
world_to_light_bin_axis(float3 world)
{
	const float3 bin_f = (world - light_bin_origin) * light_bin_cell_size_inv;
	return uint32_3(clamp(bin_f, 0.f, float3(X_SLICE_COUNT, Y_SLICE_COUNT, Z_SLICE_COUNT) - 1.f));
}

// material
structured_buffer<material> material_buffer reg(t0, space2);

material
load_material(uint32 idx)
{
	if (idx == invalid_id_uint32)
	{
		material m;
		m.base_color_factor	   = float4(1.0, 1.0, 1.0, 1.0);
		m.metallic_factor	   = 0.0;
		m.roughness_factor	   = 0.5;
		m.emissive_factor	   = float3(0.0, 0.0, 0.0);
		m.normal_scale		   = 1.0;
		m.occlusion_strength   = 1.0;
		m.alpha_cutoff		   = 0.5;
		m.alpha_mode_and_extra = 0;	   // alpha_mode = opaque(0), extra = 0
		m._					   = uint2(0, 0);

		m.base_color_texture_id			= invalid_id_uint32;
		m.metallic_roughness_texture_id = invalid_id_uint32;
		m.normal_texture_id				= invalid_id_uint32;
		m.occlusion_texture_id			= invalid_id_uint32;
		m.emissive_texture_id			= invalid_id_uint32;

		return m;
	}
	else
	{
		return material_buffer[idx];
	}
}

