bool
ddgi_enabled()
{
	return ddgi_enabled_and_extra & 1;
}

ddgi_data
load_ddgi_data()
{
	return load<ddgi_data>(static_buffer, DDGI_DATA_OFFSET);
}

uint16
load_ddgi_ppl_log2(const ddgi_data data)
{
	return uint32_w_to_uint8<uint16>(data.ppl_log_2_and_ppl_bitwidth);
}

uint16
load_ddgi_tile_count_w_log2(const ddgi_data data)
{
	return uint32_y_to_uint8<uint16>(data.level_count__tile_count_w_log2);
}

uint16
load_ddgi_level_count(const ddgi_data data)
{
	return uint32_x_to_uint8<uint16>(data.level_count__tile_count_w_log2);
}

uint32
load_ddgi_ppl(const ddgi_data data)
{
	return 1u << uint32_w_to_uint8(data.ppl_log_2_and_ppl_bitwidth);
}

uint32
ddgi_calc_probe_count(const ddgi_data data)
{
	return load_ddgi_ppl(data) * load_ddgi_level_count(data);
}

uint32_3
load_ddgi_ppl_axis(const ddgi_data data)
{
	return uint32_3(1u << uint32_x_to_uint8(data.ppl_log_2_and_ppl_bitwidth),
					1u << uint32_y_to_uint8(data.ppl_log_2_and_ppl_bitwidth),
					1u << uint32_z_to_uint8(data.ppl_log_2_and_ppl_bitwidth));
}

uint16_3
load_ddgi_ppl_log2_axis(const ddgi_data data)
{
	return uint16_3(uint32_x_to_uint8<uint16>(data.ppl_log_2_and_ppl_bitwidth),
					uint32_y_to_uint8<uint16>(data.ppl_log_2_and_ppl_bitwidth),
					uint32_z_to_uint8<uint16>(data.ppl_log_2_and_ppl_bitwidth));
}

uint32_3
load_ddgi_probe_count_axis(const uint16_3 ppl_log2_axis)
{
	return uint32_3(
		1u << ppl_log2_axis.x,
		1u << ppl_log2_axis.y,
		1u << ppl_log2_axis.z);
}

uint32_3
load_ddgi_probe_count_axis(const ddgi_data data)
{
	return load_ddgi_probe_count_axis(load_ddgi_ppl_log2_axis(data));
}

ddgi_probe
load_ddgi_probe_srv(uint32 probe_id)
{
	return ddgi_probe_buffer_srv[probe_id];
}

ddgi_probe
load_ddgi_probe_uav(uint32 probe_id)
{
	return ddgi_probe_buffer_uav[probe_id];
}

void
store_ddgi_probe_uav(uint32 probe_id, ddgi_probe p)
{
	ddgi_probe_buffer_uav[probe_id] = p;
}

float3
ddgi_level_spacing(const ddgi_data data, uint32 lv)
{
	return data.base_probe_spacing * (1u << lv);
}

// float3
// ddgi_level_extent(const ddgi_data data, uint32 lv)
//{
//	return ddgi_level_spacing(data, lv) * data.probe_per_level_axis_float;
// }

float3
ddgi_level_probe_radius(const ddgi_data data, uint32 lv)
{
	float3 probe_per_level_axis_float = float3(load_ddgi_ppl_axis(data));
	return ddgi_level_spacing(data, lv) * (probe_per_level_axis_float * 0.5f - 0.5f);
}

void
ddgi_clear_probe_msme(inout ddgi_probe probe)
{
	probe.msme.mean_long	 = 0.f;
	probe.msme.mean_short	 = 0.f;
	probe.msme.variance		 = 0.f;
	probe.msme.inconsistency = 1.f;
	probe.msme.vbbr			 = 1.f;
}

bool
ddgi_debug_flags_render_probe_in_hole(const ddgi_data data)
{
	return data.debug_flags & DDGI_DEBUG_FLAGS_RENDER_PROBE_IN_HOLE;
}

bool
ddgi_debug_flags_render_irradiance(const ddgi_data data)
{
	return data.debug_flags & DDGI_DEBUG_FLAGS_RENDER_IRRADIANCE;
}

bool
ddgi_debug_flags_render_visibility(const ddgi_data data)
{
	return data.debug_flags & DDGI_DEBUG_FLAGS_RENDER_VISIBILITY;
}

bool
ddgi_debug_flags_render_front_back(const ddgi_data data)
{
	return data.debug_flags & DDGI_DEBUG_FLAGS_RENDER_FRONT_BACK;
}

bool
ddgi_debug_flags_render_level(const ddgi_data data)
{
	return data.debug_flags & DDGI_DEBUG_FLAGS_RENDER_LEVEL;
}

bool
ddgi_debug_flags_render_weight_sum(const ddgi_data data)
{
	return data.debug_flags & DDGI_DEBUG_FLAGS_RENDER_WEIGHT_SUM;
}

bool
ddgi_debug_flags_render_ray_count(const ddgi_data data)
{
	return data.debug_flags & DDGI_DEBUG_FLAGS_RENDER_RAY_COUNT;
}

bool
ddgi_debug_flags_render_state(const ddgi_data data)
{
	return data.debug_flags & DDGI_DEBUG_FLAGS_RENDER_STATE;
}

bool
ddgi_debug_flag_render_msme(const ddgi_data data)
{
	return data.debug_flags & DDGI_DEBUG_FLAGS_RENDER_MSME;
