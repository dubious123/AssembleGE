// ddgi
structured_buffer<ddgi_probe>	 ddgi_probe_buffer_srv reg(t1, space7);
rw_structured_buffer<ddgi_probe> ddgi_probe_buffer_uav reg(u1, space7);

rw_byte_address_buffer ddgi_scratch_buffer reg(u2, space7);

void
ddgi_clear_probe_weight(uint32 probe_id)
{
	store<uint32>(ddgi_scratch_buffer, probe_id * sizeof(uint32), 0u);
}

void
ddgi_add_probe_weight(uint32 probe_id, float weight)
{
	const uint32 weight_uint32 = uint32(weight * DDGI_PROBE_WEIGHT_SCALE);
	buf_interlocked_add(ddgi_scratch_buffer, probe_id * sizeof(uint32), weight_uint32);
}

float
ddgi_load_probe_weight_sum(uint32 probe_id)
{
	const uint32 weight_uint32 = load<uint32>(ddgi_scratch_buffer, probe_id * sizeof(uint32));
	return float(weight_uint32) / DDGI_PROBE_WEIGHT_SCALE;
}

