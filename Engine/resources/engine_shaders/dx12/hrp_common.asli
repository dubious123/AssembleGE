bool
ddgi_debug_flag_render_ray_factor(const ddgi_data data)
{
	return data.debug_flags & DDGI_DEBUG_FLAGS_RENDER_RAY_FACTOR;
}

uint16
ddgi_load_probe_state_and_extra(const ddgi_data data, uint32 probe_id)
{
	uint32 probe_count = ddgi_calc_probe_count(data);

	uint32 ray_state_offset = data.ray_prefix_offset + probe_count * sizeof(uint32);

	return load<uint16>(ddgi_scratch_buffer, ray_state_offset + probe_id * sizeof(uint16));
}

void
ddgi_store_probe_state_and_extra(const ddgi_data data, uint32 probe_id, uint16 probe_state)
{
	uint32 probe_count = ddgi_calc_probe_count(data);

	uint32 ray_state_offset = data.ray_prefix_offset + probe_count * sizeof(uint32);

	store<uint16>(ddgi_scratch_buffer, ray_state_offset + probe_id * sizeof(uint16), probe_state);
}

// sampler
sampler_state linear_clamp_sampler reg(s0);
sampler_state linear_wrap_sampler reg(s1);
sampler_state point_clamp_sampler reg(s2);

sampler_state
get_linear_clamp_sampler()
{
	return linear_clamp_sampler;
}

sampler_state
get_linear_wrap_sampler()
{
	return linear_wrap_sampler;
}

sampler_state
get_point_clamp_sampler()
{
	return point_clamp_sampler;
}

uint32
depth_to_bin(float linear_depth)
{
	float t = (linear_depth - cam_near_z) / (cam_far_z - cam_near_z);
	return (uint32)(t * (Z_SLICE_COUNT - 1));
}

float
safe_dot_camera_forward(float3 dir)
{
	return max(dot(dir, camera_forward), epsilon_1e4);
}

