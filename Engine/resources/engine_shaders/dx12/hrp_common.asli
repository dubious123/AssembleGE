byte_address_buffer static_buffer reg(t0, space0);

opaque_meshlet_render_data
load_opaque_meshlet_render_data(uint32 idx)
{
	return load<opaque_meshlet_render_data>(static_buffer, OPAQUE_MSHLT_OBJECT_DATA_OFFSET + idx * sizeof(opaque_meshlet_render_data));
}

uint16
calc_object_gen(uint32 object_id)
{
	const uint16 gen = uint16((object_id & 0xf0000000) >> 28u);
	return gen;
}

bool
is_object_id_valid(uint32 object_id)
{
	const uint32 gen = (object_id & 0xf0000000) >> 28u;
	const uint32 idx = object_id & 0x0fffffff;

	if (idx >= object_count)
	{
		return false;
	}

	const object_data obj = load<object_data>(static_buffer, OBJECT_DATA_OFFSET + idx * sizeof(object_data));

	if (obj.gen() != gen)
	{
		return false;
	}

	return true;
}

object_data
load_object_data(uint32 object_id)
{
	const uint32 gen = (object_id & 0xf0000000) >> 28u;
	return load<object_data>(static_buffer, OBJECT_DATA_OFFSET + (object_id & 0x0fffffff) * sizeof(object_data));
}

object_data
load_object_prev_data(uint32 object_id)
{
	const uint32 gen = (object_id & 0xf0000000) >> 28u;
	return load<object_data>(static_buffer, OBJECT_PREV_DATA_OFFSET + (object_id & 0x0fffffff) * sizeof(object_data));
}

