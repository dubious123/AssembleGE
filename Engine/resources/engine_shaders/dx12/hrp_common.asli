ddgi_store_ray_count(const ddgi_data ddgi_data, uint32 probe_id, uint32 ray_count)
{
	store<uint32>(ddgi_scratch_buffer, ddgi_data.ray_count_offset + probe_id * sizeof(uint32), ray_count);
}

