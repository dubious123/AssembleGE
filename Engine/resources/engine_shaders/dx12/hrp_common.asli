void
store_bin_entry_x_atomic(uint32 idx, uint32 min_idx, uint32 max_idx)
{
	buf_interlocked_min(light_bin_stage_buffer_uav, LIGHT_BIN_ENTRY_X_OFFSET + idx * sizeof(zbin_entry) + sizeof(uint32) * 0, min_idx);
	buf_interlocked_max(light_bin_stage_buffer_uav, LIGHT_BIN_ENTRY_X_OFFSET + idx * sizeof(zbin_entry) + sizeof(uint32) * 1, max_idx);
}

